  S.sel.forEach(function(cat){D[cat].forEach(function(e){if(e[4]&&e[4].length>0){pool.push({co:e[0],df:e[2],sn:e[3],an:e[4],ct:cat.replace(/^\\d+\\.\\s*/,'')});if(ap.indexOf(e[4].toLowerCase())===-1)ap.push(e[4].toLowerCase())}})});
  sh(pool);if(S.mx>0&&S.mx<pool.length)pool=pool.slice(0,S.mx);
  S.qs=pool;S.ans=0;S.cor=0;
  document.getElementById('sP').style.display='none';document.getElementById('qP').style.display='block';document.getElementById('results').classList.remove('show');
  var c=document.getElementById('qC');c.innerHTML='';
  pool.forEach(function(q,i){
    var isT=S.mode==='type';
    var d=document.createElement('div');d.className='qc';d.id='qc_'+i;
    var shtml=q.sn.replace('___','<span class="gap" id="g_'+i+'">&nbsp;</span>');
    var ih='';
    if(isT){ih='<div class="ir"><input class="qi" type="text" id="ip_'+i+'" placeholder="Type the particle…" onkeydown="if(event.key===\\'Enter\\')chkT('+i+')"><button class="btn" onclick="chkT('+i+')">Check</button><button class="btn show-btn" id="sh_'+i+'" onclick="showAns('+i+')">Show</button></div>'}
    else{var ds=dist(q.an,ap);var opts=sh([q.an.toLowerCase()].concat(ds));ih='<div class="mcg">'+opts.map(function(o,oi){return'<button class="mo" id="mc_'+i+'_'+oi+'" onclick="chkM('+i+','+oi+',\\''+o.replace(/'/g,"\\\\'")+'\\')">'+o+'</button>'}).join('')+'</div><div style="margin-top:.5rem"><button class="btn show-btn" id="sh_'+i+'" onclick="showAns('+i+')">Show</button></div>'}
    var defHtml='<button class="hint-btn" onclick="toggleHint('+i+',this)">Definition</button><div class="hint-text" id="ht_'+i+'">'+q.df+'</div>';
    d.innerHTML='<div class="qm"><span class="qn">Q'+(i+1)+' / '+pool.length+'</span><span class="qcat">'+q.ct+'</span></div>'+defHtml+'<div class="qs">'+shtml+'</div>'+ih+'<div class="fb" id="fb_'+i+'"></div>';
    c.appendChild(d)});
  upP();window.scrollTo({top:0})
}
function showAns(i){var q=S.qs[i];var g=document.getElementById('g_'+i);g.textContent=q.an;var c=document.getElementById('qc_'+i);if(!c.classList.contains('ok')&&!c.classList.contains('no')){c.classList.add('no');var f=document.getElementById('fb_'+i);f.className='fb show no';f.textContent='The answer is: '+q.an;S.ans++;upP();var ip=document.getElementById('ip_'+i);if(ip){ip.disabled=true}c.querySelectorAll('.mo').forEach(function(b){b.classList.add('dis');if(b.textContent.trim()===q.an.toLowerCase())b.classList.add('rt')})}}
function chkT(i){var q=S.qs[i];var ip=document.getElementById('ip_'+i);if(ip.disabled)return;var v=ip.value.trim().toLowerCase();if(!v)return;var ok=v===q.an.toLowerCase();ip.disabled=true;var bt=ip.parentElement.querySelector('.btn');if(bt)bt.disabled=true;var c=document.getElementById('qc_'+i);var f=document.getElementById('fb_'+i);var g=document.getElementById('g_'+i);if(ok){c.classList.add('ok');f.className='fb show ok';f.textContent='✓ Correct!';g.textContent=q.an;S.cor++}else{c.classList.add('no');f.className='fb show no';f.textContent='✗ The answer is: '+q.an;g.textContent=q.an}S.ans++;upP()}
function chkM(i,oi,pk){var q=S.qs[i];var c=document.getElementById('qc_'+i);if(c.classList.contains('ok')||c.classList.contains('no'))return;var ans=q.an.toLowerCase();var ok=pk===ans;var f=document.getElementById('fb_'+i);var g=document.getElementById('g_'+i);c.querySelectorAll('.mo').forEach(function(b){b.classList.add('dis');if(b.textContent.trim()===ans)b.classList.add('rt')});if(!ok)document.getElementById('mc_'+i+'_'+oi).classList.add('wr');if(ok){c.classList.add('ok');f.className='fb show ok';f.textContent='✓ Correct!';S.cor++}else{c.classList.add('no');f.className='fb show no';f.textContent='✗ The answer is: '+q.an}g.textContent=q.an;S.ans++;upP()}
function upP(){var t=S.qs.length;var p=t>0?Math.round(S.ans/t*100):0;document.getElementById('pF').style.width=p+'%';document.getElementById('pT').textContent=S.ans+' / '+t+' · '+S.cor+' correct';if(S.ans===t&&t>0)showR()}
function showR(){var p=Math.round(S.cor/S.qs.length*100);var e=document.getElementById('results');document.getElementById('fS').textContent=p+'%';document.getElementById('fS').className='sc'+(p>=70?' great':'');var m=document.getElementById('fM');if(p===100)m.textContent='Perfect! Outstanding work.';else if(p>=80)m.textContent='Great job! Just a few to review.';else if(p>=60)m.textContent='Good effort — review the red items.';else m.textContent="Keep practising — you'll get there!";e.classList.add('show')}
function reset(){document.getElementById('sP').style.display='block';document.getElementById('qP').style.display='none';document.getElementById('results').classList.remove('show');window.scrollTo({top:0})}
function toggleHint(i,btn){var el=document.getElementById('ht_'+i);if(el.classList.contains('show')){el.classList.remove('show');btn.classList.remove('open');btn.textContent='Definition'}else{el.classList.add('show');btn.classList.add('open');btn.textContent='Hide'}}

// MATCH MODE
function startMatch(){
  var pool=[];
  S.sel.forEach(function(cat){D[cat].forEach(function(e){if(e[4]&&e[4].length>0)pool.push({co:e[0],df:e[2],sn:e[3],an:e[4],ct:cat.replace(/^\\d+\\.\\s*/,'')})})});
  sh(pool);if(S.mx>0&&S.mx<pool.length)pool=pool.slice(0,S.mx);
  S.qs=pool;S.ans=0;S.cor=0;
  document.getElementById('sP').style.display='none';document.getElementById('qP').style.display='block';document.getElementById('results').classList.remove('show');
  var c=document.getElementById('qC');c.innerHTML='';
  // Show in batches of 5
  var batchSize=5;
  for(var b=0;b<pool.length;b+=batchSize){
    var batch=pool.slice(b,b+batchSize);
    var div=document.createElement('div');div.className='qc';div.id='mb_'+(b/batchSize);
    var pvs=sh(batch.map(function(q,i){return{idx:i+b,pv:q.co}}));
    var defs=sh(batch.map(function(q,i){return{idx:i+b,df:q.df}}));
    div.innerHTML='<div class="qm"><span class="qn">Match '+(Math.floor(b/batchSize)+1)+' / '+Math.ceil(pool.length/batchSize)+'</span></div><div class="match-wrap"><div><div class="match-col-label">Phrasal Verb</div>'+pvs.map(function(p){return'<div class="mi mpv" data-idx="'+p.idx+'" onclick="mSel(this,\\'pv\\')">'+p.pv+'</div>'}).join('')+'</div><div><div class="match-col-label">Definition</div>'+defs.map(function(d){return'<div class="mi mdf" data-idx="'+d.idx+'" onclick="mSel(this,\\'df\\')">'+d.df+'</div>'}).join('')+'</div></div><div class="fb" id="mfb_'+(b/batchSize)+'"></div>';
    c.appendChild(div);
  }
  window._mSel={pv:null,df:null};
  document.getElementById('pF').style.width='0%';
  document.getElementById('pT').textContent='Match mode · '+pool.length+' pairs';
  window.scrollTo({top:0});
}
function mSel(el,type){
  if(el.classList.contains('matched'))return;
  var ms=window._mSel;
  if(type==='pv'){document.querySelectorAll('.mpv').forEach(function(e){e.classList.remove('sel')});el.classList.add('sel');ms.pv=el}
  else{document.querySelectorAll('.mdf').forEach(function(e){e.classList.remove('sel')});el.classList.add('sel');ms.df=el}
  if(ms.pv&&ms.df){
    var pi=parseInt(ms.pv.dataset.idx);var di=parseInt(ms.df.dataset.idx);
    if(pi===di){ms.pv.classList.add('matched');ms.pv.classList.remove('sel');ms.df.classList.add('matched');ms.df.classList.remove('sel');S.cor++;S.ans++;upP()}
    else{ms.pv.classList.add('wrong');ms.df.classList.add('wrong');S.ans++;upP();setTimeout(function(){ms.pv.classList.remove('wrong','sel');ms.df.classList.remove('wrong','sel');ms.pv=null;ms.df=null},500);return}
    ms.pv=null;ms.df=null;
  }
}

// FLASHCARD MODE
var FC={cards:[],idx:0,got:0,missed:0};
function startFlash(){
  var pool=[];
  S.sel.forEach(function(cat){D[cat].forEach(function(e){if(e[4]&&e[4].length>0)pool.push({co:e[0],df:e[2],sn:e[3],an:e[4],ct:cat.replace(/^\\d+\\.\\s*/,'')})})});
  sh(pool);if(S.mx>0&&S.mx<pool.length)pool=pool.slice(0,S.mx);
  FC.cards=pool;FC.idx=0;FC.got=0;FC.missed=0;
  document.getElementById('sP').style.display='none';document.getElementById('qP').style.display='block';
  document.getElementById('results').classList.remove('show');
  var c=document.getElementById('qC');
  c.innerHTML='<div class="fc-nav"><button class="btn sec" onclick="fcPrev()">← Prev</button><span class="fc-count" id="fcCount">1 / '+pool.length+'</span><button class="btn sec" onclick="fcNext()">Next →</button></div><div id="fcCard"></div><div class="fc-score-row" id="fcScoreRow"><button class="fc-sbtn got-it" onclick="fcMark(1)">✓ Got it</button><button class="fc-sbtn missed" onclick="fcMark(0)">✗ Missed</button></div><div style="text-align:center"><span class="fc-count" id="fcScore"></span></div>';
  showFC();
  document.getElementById('pF').style.width='0%';
  document.getElementById('pT').textContent='Flashcards';
  window.scrollTo({top:0});
}
function showFC(){
  if(FC.idx>=FC.cards.length){fcDone();return}
  var q=FC.cards[FC.idx];
  var shtml=q.sn.replace('___','<span style="color:var(--accent);font-weight:700">______</span>');
  document.getElementById('fcCard').innerHTML='<div class="fc" id="fcFlip" onclick="this.classList.toggle(\\'flipped\\')"><div class="fc-inner"><div class="fc-front"><div class="fc-cat">'+q.ct+'</div><div class="fc-ex" style="margin-top:1rem">'+shtml+'</div><div style="margin-top:1rem"><button class="hint-btn" onclick="event.stopPropagation();this.nextElementSibling.classList.toggle(\\'show\\');this.classList.toggle(\\'open\\');this.textContent=this.textContent===\\'Definition\\'?\\'Hide\\':\\'Definition\\'">Definition</button><div class="hint-text">'+q.df+'</div></div><div class="fc-hint">tap to reveal</div></div><div class="fc-back"><div class="fc-ans">'+q.an+'</div><div class="fc-combo">'+q.co+'</div><div class="fc-ex">'+q.sn.replace('___','<b>'+q.an+'</b>')+'</div></div></div></div>';
  document.getElementById('fcCount').textContent=(FC.idx+1)+' / '+FC.cards.length;
  document.getElementById('fcScore').textContent='✓ '+FC.got+'  ✗ '+FC.missed;
}
function fcMark(ok){if(ok)FC.got++;else FC.missed++;FC.idx++;var p=FC.cards.length>0?Math.round(FC.idx/FC.cards.length*100):0;document.getElementById('pF').style.width=p+'%';showFC()}
function fcPrev(){if(FC.idx>0){FC.idx--;showFC()}}
function fcNext(){FC.got++;FC.idx++;var p=FC.cards.length>0?Math.round(FC.idx/FC.cards.length*100):0;document.getElementById('pF').style.width=p+'%';showFC()}
function fcDone(){var t=FC.got+FC.missed;var p=t>0?Math.round(FC.got/t*100):0;S.cor=FC.got;S.qs=FC.cards;S.ans=t;showR()}
`;


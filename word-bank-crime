<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Crime &amp; Law — Word Bank — John + English</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --sky:#2176FF;--sky-light:#E8EEFF;--sea:#1DD3B0;--sea-light:#E4FBF7;
  --coral:#FF6B6B;--coral-light:#FFE8E8;--lavender:#9B72CF;--lavender-light:#F0E8FA;
  --cream:#F7F6F3;--ink:#2D3047;--muted:#7A7D8E;--border:#E8E5DF;--card:#fff;
  --radius:14px;--radius-sm:10px;
  --shadow-sm:0 1px 3px rgba(45,48,71,.06);--shadow-md:0 4px 14px rgba(45,48,71,.08);
  --accent:#6C757D;--accent-light:#EDECED;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Outfit',sans-serif;background:var(--cream);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased}
body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(circle,var(--border) 1px,transparent 1px);background-size:28px 28px;opacity:.4;pointer-events:none;z-index:0}
.topnav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(247,246,243,.88);backdrop-filter:blur(16px);border-bottom:1.5px solid var(--border);height:52px;padding:0 2rem;display:flex;align-items:center;justify-content:space-between}
.nav-logo{font-family:'Outfit',sans-serif;font-size:1.3rem;font-weight:800;letter-spacing:-.02em;color:var(--ink);text-decoration:none}
.nav-logo span{color:var(--sky)}
.topnav-links{display:flex;gap:1.2rem;align-items:center}
.topnav-links a{font-size:.85rem;font-weight:600;color:var(--muted);text-decoration:none;transition:color .2s}
.topnav-links a:hover{color:var(--sky)}
.page-header{padding:5.5rem 2rem 1.5rem;max-width:900px;margin:0 auto;position:relative;z-index:1}
.back-link{display:inline-flex;align-items:center;gap:.4rem;font-size:.85rem;font-weight:600;color:var(--muted);text-decoration:none;margin-bottom:1.2rem;transition:color .2s}
.back-link:hover{color:var(--sky)}
.back-link svg{width:14px;height:14px}
.topic-hero{display:flex;align-items:flex-start;gap:1.2rem}
.topic-icon{width:52px;height:52px;border-radius:12px;background:var(--accent-light);color:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.topic-icon svg{width:24px;height:24px;stroke-width:1.8;fill:none;stroke:currentColor}
.section-label{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:.3rem}
.page-header h1{font-family:'Outfit',sans-serif;font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;letter-spacing:-.01em;line-height:1.1;margin-bottom:.4rem}
.page-header p{color:var(--muted);font-size:.9rem;max-width:540px;line-height:1.6}
.header-meta{margin-top:.8rem}
.meta-count{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--muted)}
.tabs-wrap{max-width:900px;margin:0 auto;padding:0 2rem;position:relative;z-index:1}
.tabs{display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:2rem;align-items:center}
.tab{font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:700;padding:.7rem 1.4rem;border:none;background:none;color:var(--muted);cursor:pointer;border-bottom:2.5px solid transparent;margin-bottom:-2px;transition:color .2s}
.tab:hover{color:var(--ink)}
.tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.main{max-width:900px;margin:0 auto;padding:0 2rem 4rem;position:relative;z-index:1}
.panel{display:none}
.panel.active{display:block}
.filter-bar{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem}
.cat-btn{font-family:'Outfit',sans-serif;font-size:.8rem;font-weight:700;padding:.4rem 1rem;border:1.5px solid var(--border);border-radius:20px;background:var(--card);color:var(--muted);cursor:pointer;transition:all .18s}
.cat-btn:hover{border-color:var(--accent);color:var(--accent)}
.cat-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
.cat-section{margin-bottom:1.4rem;background:var(--card);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-sm)}
.cat-header{display:flex;align-items:center;justify-content:space-between;gap:.7rem;padding:.5rem 1rem;background:var(--accent-light);border-bottom:1.5px solid var(--border);border-left:3px solid var(--accent);cursor:pointer;user-select:none}
.cat-header:hover{filter:brightness(.97)}
.cat-title{font-family:'Outfit',sans-serif;font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--accent)}
.cat-chevron{color:var(--accent);transition:transform .2s;font-size:.75rem;opacity:.7;flex-shrink:0}
.cat-section.collapsed .cat-chevron{transform:rotate(-90deg)}
.cat-section.collapsed .cat-body{display:none}
.pos-group{margin-bottom:.1rem}
.pos-subhead{font-family:'JetBrains Mono',monospace;font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;padding:.38rem 1rem .3rem;border-bottom:1px solid var(--border);border-top:1px solid var(--border);border-left:3px solid transparent;cursor:pointer;display:flex;align-items:center;justify-content:space-between;user-select:none}
.pos-subhead:hover{filter:brightness(.96)}
.pos-chevron{transition:transform .2s;font-size:.65rem;opacity:.6;flex-shrink:0}
.pos-group.collapsed .pos-chevron{transform:rotate(-90deg)}
.pos-group.collapsed .pos-body{display:none}
.pos-group:first-child .pos-subhead{border-top:none}
.word-list{width:100%}
.word-row{border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s;padding:.5rem 1rem}
.word-row:last-child{border-bottom:none}
.word-row:hover{background:var(--accent-light)}
.word-row.open{background:var(--accent-light)}
.wr-main{display:flex;align-items:center;gap:.5rem}
.wr-term{font-weight:800;font-size:.88rem;line-height:1.4}
.wr-arr{margin-left:auto;font-size:1rem;color:var(--border);transition:transform .15s,color .15s;flex-shrink:0;padding-left:.5rem}
.word-row.open .wr-arr{transform:rotate(90deg);color:var(--muted)}
.wr-def{font-size:.8rem;color:var(--muted);line-height:1.4;margin-top:.15rem}
.wr-ex{display:none;font-size:.78rem;font-style:italic;color:var(--muted);margin-top:.25rem;padding:.3rem .5rem;border-left:2px solid var(--border);line-height:1.5}
.word-row.open .wr-ex{display:block}
.conv-controls{display:flex;align-items:center;gap:.5rem;margin-bottom:1.2rem}
.conv-ctrl-label{font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-right:.2rem}
.conv-hide-btn{font-family:'Outfit',sans-serif;font-size:.8rem;font-weight:700;padding:.35rem .8rem;border:1.5px solid var(--border);border-radius:20px;background:var(--card);color:var(--muted);cursor:pointer;transition:all .18s}
.conv-hide-btn:hover{border-color:var(--ink);color:var(--ink)}
.conv-hide-btn.active-a{background:var(--sky);border-color:var(--sky);color:#fff}
.conv-hide-btn.active-b{background:var(--sea);border-color:var(--sea);color:#fff}
.hide-a .conv-speaker-a ~ span{visibility:hidden}
.hide-b .conv-speaker-b ~ span{visibility:hidden}
.conv-section{margin-bottom:1.4rem;background:var(--card);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-sm)}
.conv-section.collapsed .cat-body{display:none}
.conv-section.collapsed .cat-chevron{transform:rotate(-90deg)}
.conv-header{display:flex;align-items:center;justify-content:space-between;gap:.7rem;padding:.5rem 1rem;background:var(--sea-light);border-bottom:1.5px solid var(--border);border-left:3px solid var(--sea);cursor:pointer;user-select:none}
.conv-title{font-family:'Outfit',sans-serif;font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--sea)}
.conv-entry{border-bottom:1px solid var(--border);padding:.65rem 1rem}
.conv-entry:last-child{border-bottom:none}
.conv-dialogue{display:flex;flex-direction:column;gap:.25rem;margin-bottom:.35rem}
.conv-line{font-size:.82rem;line-height:1.5;display:grid;grid-template-columns:16px 1fr;gap:.5rem}
.conv-speaker{font-family:'JetBrains Mono',monospace;font-size:.6rem;font-weight:700;padding-top:.18rem}
.conv-speaker-a{color:var(--sky)}
.conv-speaker-b{color:var(--sea)}
.conv-note{font-size:.73rem;color:var(--muted);font-style:italic;padding-left:24px}
.print-btn{margin-left:auto;display:inline-flex;align-items:center;gap:.45rem;font-family:'Outfit',sans-serif;font-size:.82rem;font-weight:600;padding:.45rem .9rem;border:1.5px solid var(--border);border-radius:10px;background:var(--card);color:var(--ink);cursor:pointer;transition:all .18s;flex-shrink:0}
.print-btn:hover{border-color:var(--ink);background:var(--ink);color:var(--cream)}
@media print{.print-btn{display:none}}
.print-modal-backdrop{position:fixed;inset:0;background:rgba(45,48,71,.5);backdrop-filter:blur(3px);z-index:1000;display:none;align-items:center;justify-content:center;padding:1rem}
.print-modal-backdrop.open{display:flex}
.print-modal{background:var(--card);border-radius:var(--radius);max-width:440px;width:100%;padding:1.8rem;box-shadow:0 20px 60px rgba(45,48,71,.25);max-height:90vh;overflow-y:auto}
.print-modal h3{font-family:'Outfit',sans-serif;font-size:1.4rem;font-weight:800;color:var(--ink);margin-bottom:.3rem}
.print-modal-desc{font-size:.85rem;color:var(--muted);margin-bottom:1.4rem}
.print-field{margin-bottom:1.1rem}
.print-field-label{font-family:'JetBrains Mono',monospace;font-size:.65rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.5rem;display:block}
.print-opts{display:flex;flex-direction:column;gap:.4rem}
.print-opt{display:flex;align-items:flex-start;gap:.6rem;padding:.65rem .8rem;border:1.5px solid var(--border);border-radius:10px;cursor:pointer;transition:all .15s;background:#fff}
.print-opt:hover{border-color:var(--muted);background:var(--cream)}
.print-opt input{margin:.15rem 0 0 0;accent-color:var(--accent);cursor:pointer;flex-shrink:0}
.print-opt-content{flex:1;display:flex;flex-direction:column;gap:.1rem}
.print-opt-title{font-size:.9rem;font-weight:700;color:var(--ink);line-height:1.3}
.print-opt-desc{font-size:.78rem;color:var(--muted);line-height:1.4}
.print-opt:has(input:checked){border-color:var(--accent);background:var(--accent-light)}
.print-opt:has(input:checked) .print-opt-title{color:var(--accent)}
.print-actions{display:flex;gap:.6rem;margin-top:1.4rem;justify-content:flex-end}
.print-btn-cancel{font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:700;padding:.6rem 1.2rem;border-radius:10px;cursor:pointer;background:var(--card);border:1.5px solid var(--border);color:var(--muted);transition:all .15s}
.print-btn-cancel:hover{border-color:var(--muted);color:var(--ink)}
.print-btn-go{font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:700;padding:.6rem 1.2rem;border-radius:10px;cursor:pointer;background:var(--accent);border:1.5px solid var(--accent);color:#fff;transition:opacity .15s}
.print-btn-go:hover{opacity:.85}
.empty-state{text-align:center;padding:3rem;color:var(--muted);font-size:.9rem}
.tap-hint{font-size:.75rem;color:var(--muted);margin-bottom:.8rem;font-style:italic}
@media(max-width:600px){.page-header{padding:5rem 1.2rem 1.2rem}.main,.tabs-wrap{padding:0 1.2rem 3rem}}
</style>
</head>

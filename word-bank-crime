  </div>
</div>
<div class="page-header">
  <a class="back-link" href="word-banks.html">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Word Banks
  </a>
  <div class="topic-hero">
    <div class="topic-icon"><svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
    <div>
      <div class="section-label">Word Bank</div>
      <h1>Crime &amp; Law</h1>
      <p>Vocabulary for discussing crime, justice, punishment, and the legal system.</p>
      <div class="header-meta"><span class="meta-count" id="totalCount"></span></div>
    </div>
  </div>
</div>
<div class="tabs-wrap">
  <div class="tabs">
    <button class="tab active" onclick="switchTab('browse',this)">Browse</button>
    <button class="tab" onclick="switchTab('conversation',this)">Conversation</button>
    <button class="print-btn" onclick="openPrintModal()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      Print
    </button>
  </div>
</div>
<div class="main">
  <div class="panel active" id="panel-browse">
    <div class="filter-bar">
      <button class="cat-btn active" onclick="filterCat('all',this)">All</button>
      <button class="cat-btn" onclick="filterCat('tier1',this)">Tier 1 — Essential</button>
      <button class="cat-btn" onclick="filterCat('tier2',this)">Tier 2 — Intermediate</button>
      <button class="cat-btn" onclick="filterCat('tier3',this)">Tier 3 — Advanced</button>
    </div>
    <div id="browse-content"></div>
  </div>
  <div class="panel" id="panel-conversation">
    <div class="conv-controls">
      <span class="conv-ctrl-label">Practise</span>
      <button class="conv-hide-btn" id="conv-hide-a" onclick="toggleHide('A')">Hide A</button>
      <button class="conv-hide-btn" id="conv-hide-b" onclick="toggleHide('B')">Hide B</button>
    </div>
    <div id="conv-content"></div>
  </div>
</div>
<script>
const CATEGORIES = [
  { key: 'tier1', label: 'Tier 1 — Essential' },
  { key: 'tier2', label: 'Tier 2 — Intermediate' },
  { key: 'tier3', label: 'Tier 3 — Advanced' },
];
const DATA = {{
      tier1: [
    ['crime','n.','an illegal act punishable by law','Crime rates have fallen slightly in the last year.'],
    ['victim','n.','a person who has been harmed by a crime or accident','The victim was taken to hospital with minor injuries.'],
    ['witness','n.','a person who sees a crime or event take place','The witness described the suspect to the police.'],
    ['suspect','n.','a person believed to have committed a crime','Police arrested a suspect within hours of the robbery.'],
    ['evidence','n.','information or objects used to prove something in a legal case','The DNA evidence was crucial to securing the conviction.'],
    ['sentence','n.','the punishment given to someone found guilty of a crime','He received a five-year prison sentence.'],
    ['fine','n.','a sum of money paid as a punishment for breaking a law','She got a two-hundred-euro fine for speeding.'],
    ['guilty','adj.','responsible for committing a crime; proven to have broken the law','The jury found him guilty on all charges.'],
    ['innocent','adj.','not guilty of a crime','He was found innocent after new evidence came to light.'],
    ['illegal','adj.','against the law; not permitted','It\'s illegal to drive without insurance.'],
    ['steal','v.','to take something that belongs to someone else without permission','Someone stole her phone on the metro.'],
    ['arrest','v.','to take someone into police custody for a suspected crime','He was arrested on suspicion of fraud.'],
    ['break into','phr.v.','to enter a building illegally, usually by force','Someone broke into the office over the weekend.'],
    ['get away with','phr.v.','to avoid punishment for something wrong or illegal','He lied on his CV and got away with it for years.'],
    ['turn oneself in','phr.v.','to surrender to the police voluntarily','He turned himself in after three days on the run.'],
    ['commit a crime','colloc.','to carry out an illegal act','He committed the crime in broad daylight.'],
    ['caught red-handed','idiom','caught in the act of doing something wrong','She was caught red-handed shoplifting from the supermarket.'],
    ['robbery','n.','the crime of stealing from a person or place using force or threat','There was an armed robbery at the bank on the high street.'],
    ['punishment','n.','a penalty imposed for breaking a law or rule','The punishment should fit the crime.'],
  ],
  tier2: [
    ['fraud','n.','the crime of deceiving someone for financial or personal gain','He was charged with fraud after faking his qualifications.'],
    ['bribery','n.','the act of offering money or favours to influence someone\'s behaviour','Bribery of public officials carries a prison sentence.'],
    ['verdict','n.','the decision of a jury or judge at the end of a trial','The jury reached a verdict of not guilty.'],
    ['bail','n.','money paid to release an accused person from custody until trial','He was released on bail pending a full hearing.'],
    ['deterrent','n.','something that discourages someone from committing a crime','Longer sentences are not always an effective deterrent.'],
    ['juvenile','adj.','relating to young people, especially those who commit crimes','Juvenile crime has become a growing concern in urban areas.'],
    ['crack down on','phr.v.','to take severe measures against illegal activity','Police have cracked down on knife crime in the area.'],
    ['lock up','phr.v.','to put someone in prison','He was locked up for eight years for armed robbery.'],
    ['cover up','phr.v.','to hide evidence of wrongdoing or a crime','The company tried to cover up the safety violations.'],
    ['let off','phr.v.','to give someone little or no punishment','He was let off with a warning for his first offence.'],
    ['take the law into your own hands','idiom','to punish someone yourself instead of calling the police','You can\'t take the law into your own hands, however angry you are.'],
    ['behind bars','idiom','in prison','He spent ten years behind bars before being released.'],
    ['above the law','idiom','not subject to the same rules as everyone else','Nobody should be above the law, regardless of their status.'],
  ],
  tier3: [
    ['rehabilitation','n.','the process of helping someone reintegrate into society after prison','The programme focuses on rehabilitation rather than punishment.'],
    ['recidivism','n.','the tendency of a convicted criminal to reoffend','Recidivism rates remain stubbornly high despite reform efforts.'],
    ['white-collar','adj.','relating to non-violent crime committed by business or professional people','White-collar crime often goes unpunished compared to street crime.'],
    ['extenuating','adj.','(of circumstances) making an offence seem less serious','The judge considered the extenuating circumstances before sentencing.'],
    ['acquit','v.','to formally declare someone not guilty of a criminal charge','She was acquitted of all charges due to lack of evidence.'],
    ['fit up','phr.v.','to falsely incriminate someone by fabricating evidence (British informal)','He always claimed he\'d been fitted up by the police.'],
    ['a slippery slope','idiom','a course of action that seems small but leads to serious consequences','Bending the rules even slightly is a slippery slope.'],
    ['the long arm of the law','idiom','the far-reaching power of the legal system','You can run, but the long arm of the law will catch up with you.'],
  ],
    };

const CONV_DATA = [];
const POS_COLORS = {"n.":["#2176FF","#F0EFEC"],"adj.":["#FF9100","#F0EFEC"],"v.":["#0FA67F","#F0EFEC"],"phr.v.":["#D946A8","#F0EFEC"],"colloc.":["#D4A017","#F0EFEC"],"idiom":["#CC2936","#F0EFEC"],"phrase":["#7A7D8E","#F0EFEC"],"slang":["#7B3FF2","#F0EFEC"]};
const POS_ORDER = ['n.','adj.','v.','phr.v.','colloc.','idiom','phrase','slang'];
const POS_LABELS = {'n.':'Nouns','adj.':'Adjectives','v.':'Verbs','phr.v.':'Phrasal Verbs','colloc.':'Collocations','idiom':'Idioms','phrase':'Set Phrases','slang':'Modern Slang'};
let activeCat = 'all';
let hiddenSpeaker = null;
function renderBrowse() {
  const container = document.getElementById('browse-content');
  const cats = activeCat === 'all' ? CATEGORIES : CATEGORIES.filter(c=>c.key===activeCat);
  let html = ''; let total = 0;
  const groups = {};
  cats.forEach(cat => {
    const entries = DATA[cat.key]||[];
    if (!entries.length) return;
    total += entries.length;
    entries.forEach(function(e){ var pos=e[1]; if(!groups[pos]) groups[pos]=[]; groups[pos].push(e); });
  });
  html += '<div class="cat-section"><div class="cat-body">';
  POS_ORDER.forEach(function(pos){
    if (!groups[pos]) return;
    var label = POS_LABELS[pos]||pos;
    var fg = (POS_COLORS[pos]||['var(--muted)'])[0];
    var bg = (POS_COLORS[pos]||['','var(--cream)'])[1];
    html += '<div class="pos-group collapsed">'
      + '<div class="pos-subhead" style="color:var(--muted);background:'+bg+';border-left-color:'+fg+'" onclick="togglePos(this)">'
      + label + '<span class="pos-chevron">&#9660;</span>'
      + '</div>'
      + '<div class="pos-body">';
    groups[pos].forEach(function(e){
      var term=e[0], def=e[2], ex=e[3]||'';
      html += '<div class="word-row" onclick="toggleRow(this)">'
        + '<div class="wr-main"><span class="wr-term">'+term+'</span><span class="wr-arr">&#8250;</span></div>'
        + '<div class="wr-def">'+def+'</div>'
        + (ex ? '<div class="wr-ex">'+ex+'</div>' : '')
        + '</div>';
    });
    html += '</div></div>';
  });
  html += '</div></div>';
  html = '<p class="tap-hint">Tap any word to see an example sentence.</p>' + html;
  if (!total) html = '<div class="empty-state">No items.</div>';
  container.innerHTML = html;
  document.getElementById('totalCount').textContent = total + ' items';
}

function toggleRow(row){ row.classList.toggle('open'); }
function filterCat(cat, btn) {
  activeCat = cat;
  document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderBrowse();
}
function renderConversation() {
  const container = document.getElementById('conv-content');
  let html = '';
  CONV_DATA.forEach(section => {
    html += '<div class="conv-section collapsed"><div class="conv-header" onclick="toggleCat(this)"><span class="conv-title">'+section.group+'</span><span class="cat-chevron" style="color:var(--sea)">&#9660;</span></div><div class="cat-body">';
    section.entries.forEach(e => {
      const lines = e.lines.map((l,i) => {
        const scls = i===0?'conv-speaker-a':'conv-speaker-b';
        const lbl = i===0?'A':'B';
        return '<div class="conv-line"><span class="conv-speaker '+scls+'">'+lbl+'</span><span>'+l[1]+'</span></div>';
      }).join('');
      html += '<div class="conv-entry"><div class="conv-dialogue">'+lines+'</div><div class="conv-note">'+e.note+'</div></div>';
    });
    html += '</div></div>';
  });
  container.innerHTML = html;
}
function toggleHide(speaker) {
  const container = document.getElementById('conv-content');
  if (hiddenSpeaker === speaker) {
    hiddenSpeaker = null;
    container.classList.remove('hide-a','hide-b');
    document.getElementById('conv-hide-a').classList.remove('active-a');
    document.getElementById('conv-hide-b').classList.remove('active-b');
  } else {
    hiddenSpeaker = speaker;
    container.classList.remove('hide-a','hide-b');
    container.classList.add('hide-'+speaker.toLowerCase());
    document.getElementById('conv-hide-a').classList.remove('active-a');
    document.getElementById('conv-hide-b').classList.remove('active-b');
    document.getElementById('conv-hide-'+speaker.toLowerCase()).classList.add('active-'+speaker.toLowerCase());
  }
}
function switchTab(id, btn) {
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  btn.classList.add('active');
}
function toggleCat(hdr) { hdr.parentElement.classList.toggle('collapsed'); }
function togglePos(hdr) { hdr.parentElement.classList.toggle('collapsed'); }
function openPrintModal() {
  var scope = document.querySelector('input[name="wbScope"]:checked').value;
  document.getElementById('print-format-field').style.display = scope === 'conversation' ? 'none' : '';
  document.getElementById('printModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closePrintModal(e) {
  if (e && e.target !== document.getElementById('printModal')) return;
  document.getElementById('printModal').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('change', function(e) {
  if (e.target.name === 'wbScope') document.getElementById('print-format-field').style.display = e.target.value === 'conversation' ? 'none' : '';
});
function executePrint() {
  var scope = document.querySelector('input[name="wbScope"]:checked').value;
  var format = document.querySelector('input[name="wbFormat"]:checked').value;
  var topic = 'Crime & Law';
  var html = '<!DOCTYPE html><html><head><meta charset="UTF-8"><title>'+topic+' — Word Bank</title>'
    + '<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">'
    + '<style>@page{margin:1.4cm 1.8cm}*{margin:0;padding:0;box-sizing:border-box}'
    + 'body{font-family:Outfit,sans-serif;color:#2D3047;font-size:10pt;line-height:1.5}'
    + '.header{display:flex;align-items:baseline;justify-content:space-between;border-bottom:2pt solid #E8E5DF;padding-bottom:4pt;margin-bottom:10pt}'
    + 'h1{font-family:Outfit,sans-serif;font-size:17pt;font-weight:900}'
    + '.meta{font-family:"JetBrains Mono",monospace;font-size:7.5pt;color:#7A7D8E}'
    + '.tier{margin-bottom:16pt}'
    + '.tier-name{font-family:"JetBrains Mono",monospace;font-size:7pt;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#9B72CF;padding:3pt 0;border-bottom:1.5pt solid #E8E5DF;margin-bottom:4pt}'
    + '.pos-name{font-family:"JetBrains Mono",monospace;font-size:6.5pt;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#7A7D8E;margin:6pt 0 2pt;padding-top:4pt;border-top:0.5pt solid #f0ede8}'
    + '.pos-name:first-child{border-top:none;margin-top:0}'
    + 'table{width:100%;border-collapse:collapse;margin-bottom:4pt}'
    + 'td{padding:3pt 5pt;vertical-align:top;border-bottom:0.5pt solid #f5f3ef;font-size:10pt}'
    + 'td.term{font-weight:800;width:26%}td.def{color:#555;width:40%}td.ex{font-style:italic;color:#888;width:34%}'
    + 'td.ws-line{border-bottom:1pt solid #bbb;min-width:200pt}'
    + '.conv-group{margin-bottom:14pt}'
    + '.conv-group-name{font-family:"JetBrains Mono",monospace;font-size:7pt;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#1DD3B0;padding:3pt 0;border-bottom:1.5pt solid #E8E5DF;margin-bottom:6pt}'
    + '.conv-entry{margin-bottom:8pt}'
    + '.conv-line{display:grid;grid-template-columns:14pt 1fr;gap:3pt;font-size:10pt;line-height:1.6}'
    + '.spk{font-family:"JetBrains Mono",monospace;font-size:7pt;font-weight:700;padding-top:2pt}'
    + '.spk-a{color:#2176FF}.spk-b{color:#1DD3B0}'
    + '.conv-note{font-size:8.5pt;font-style:italic;color:#7A7D8E;margin-top:2pt;padding-left:17pt}'
    + '</style></head><body>'
    + '<div class="header"><h1>'+topic+'</h1>'
    + '<span class="meta">'+(scope==='conversation'?'Conversation Exchanges':(scope==='all'?'All Tiers':CATEGORIES.find(function(c){return c.key===scope;}).label))+'</span></div>';
  if (scope === 'conversation') {
    CONV_DATA.forEach(function(section) {
      html += '<div class="conv-group"><div class="conv-group-name">'+section.group+'</div>';
      section.entries.forEach(function(e) {
        html += '<div class="conv-entry">';
        e.lines.forEach(function(l,i) {
          html += '<div class="conv-line"><span class="spk '+(i===0?'spk-a':'spk-b')+'">'+(i===0?'A':'B')+'</span><span>'+l[1]+'</span></div>';
        });
        html += '<div class="conv-note">'+e.note+'</div></div>';
      });
      html += '</div>';
    });
  } else {
    var tiers = scope === 'all' ? ['tier1','tier2','tier3'] : [scope];
    tiers.forEach(function(tk) {
      var cat = CATEGORIES.find(function(c){return c.key===tk;});
      if (!cat) return;
      var entries = DATA[tk]||[];
      if (!entries.length) return;
      html += '<div class="tier"><div class="tier-name">'+cat.label+'</div>';
      var groups = {};
      entries.forEach(function(e){ if(!groups[e[1]]) groups[e[1]]=[]; groups[e[1]].push(e); });
      ['n.','adj.','v.','phr.v.','colloc.','idiom','phrase','slang'].forEach(function(pos) {
        if (!groups[pos]) return;
        var pl = {'n.':'Nouns','adj.':'Adjectives','v.':'Verbs','phr.v.':'Phrasal Verbs','colloc.':'Collocations','idiom':'Idioms','phrase':'Set Phrases','slang':'Modern Slang'};
        html += '<div class="pos-name">'+pl[pos]+'</div><table>';
        groups[pos].forEach(function(e) {
          if (format==='full') html += '<tr><td class="term">'+e[0]+'</td><td class="def">'+e[2]+'</td><td class="ex">'+(e[3]||'')+'</td></tr>';
          else if (format==='compact') html += '<tr><td class="term">'+e[0]+'</td><td class="def">'+e[2]+'</td></tr>';
          else html += '<tr><td class="term">'+e[0]+'</td><td class="ws-line"></td></tr>';
        });
        html += '</table>';
      });
      html += '</div>';
    });
  }
  html += '</body></html>';
  var win = window.open('','_blank');
  win.document.write(html);
  win.document.close();
  win.onload = function(){ win.focus(); win.print(); };
  document.getElementById('printModal').classList.remove('open');
  document.body.style.overflow = '';
}
renderBrowse();
renderConversation();
</script>
<div class="print-modal-backdrop" id="printModal" onclick="closePrintModal(event)">
  <div class="print-modal" onclick="event.stopPropagation()">
    <h3>Print word bank</h3>
    <p class="print-modal-desc">Choose what to print.</p>
    <div class="print-field">
      <label class="print-field-label">Scope</label>
      <div class="print-opts">
        <label class="print-opt"><input type="radio" name="wbScope" value="all" checked><div class="print-opt-content"><span class="print-opt-title">All tiers</span><span class="print-opt-desc">Everything — Tier 1, 2, and 3</span></div></label>
        <label class="print-opt"><input type="radio" name="wbScope" value="tier1"><div class="print-opt-content"><span class="print-opt-title">Tier 1 only</span><span class="print-opt-desc">Essential vocabulary</span></div></label>
        <label class="print-opt"><input type="radio" name="wbScope" value="tier2"><div class="print-opt-content"><span class="print-opt-title">Tier 2 only</span><span class="print-opt-desc">Intermediate vocabulary</span></div></label>
        <label class="print-opt"><input type="radio" name="wbScope" value="tier3"><div class="print-opt-content"><span class="print-opt-title">Tier 3 only</span><span class="print-opt-desc">Advanced vocabulary</span></div></label>
        <label class="print-opt"><input type="radio" name="wbScope" value="conversation"><div class="print-opt-content"><span class="print-opt-title">Conversation exchanges</span><span class="print-opt-desc">Dialogues and usage notes only</span></div></label>
      </div>
    </div>
    <div class="print-field" id="print-format-field">
      <label class="print-field-label">Format</label>
      <div class="print-opts">
        <label class="print-opt"><input type="radio" name="wbFormat" value="full" checked><div class="print-opt-content"><span class="print-opt-title">Full reference</span><span class="print-opt-desc">Term, definition, and example sentence</span></div></label>
        <label class="print-opt"><input type="radio" name="wbFormat" value="compact"><div class="print-opt-content"><span class="print-opt-title">Compact</span><span class="print-opt-desc">Term and definition only</span></div></label>
        <label class="print-opt"><input type="radio" name="wbFormat" value="worksheet"><div class="print-opt-content"><span class="print-opt-title">Worksheet</span><span class="print-opt-desc">Terms listed with blank lines for definitions</span></div></label>
      </div>
    </div>
    <div class="print-actions">
      <button class="print-btn-cancel" onclick="closePrintModal()">Cancel</button>
      <button class="print-btn-go" onclick="executePrint()">Print</button>
    </div>
  </div>
</div>
</body>
</html>

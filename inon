<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IN or ON? — JohnPlusEnglish</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --blue: #2176FF;
    --orange: #FF9100;
    --red: #EF233C;
    --yellow: #FFDD4A;
    --dark: #1A1A2E;
    --mid: #3A3A52;
    --grey: #888899;
    --light: #F2F2F7;
    --correct: #1DD3B0;
    --wrong: #EF233C;
  }

  body { font-family: 'Outfit', sans-serif; background: var(--light); color: var(--dark); min-height: 100vh; }

  /* ── HEADER ── */
  .site-header { background: var(--dark); padding: 22px 40px; display: flex; align-items: center; justify-content: space-between; }
  .logo { font-size: 20px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: #fff; }
  .logo span { color: var(--yellow); }
  .brand-dots { display: flex; gap: 8px; }
  .brand-dots span { width: 11px; height: 11px; border-radius: 50%; display: block; }
  .brand-dots span:nth-child(1) { background: var(--red); }
  .brand-dots span:nth-child(2) { background: var(--yellow); }
  .brand-dots span:nth-child(3) { background: var(--blue); }

  /* ── HERO ── */
  .hero { background: var(--dark); padding: 0 40px 34px; text-align: center; }
  .hero h1 { font-size: clamp(50px, 9vw, 86px); font-weight: 900; letter-spacing: -0.04em; line-height: 1; color: #fff; }
  .hero h1 .in { color: var(--blue); }
  .hero h1 .or { color: rgba(255,255,255,0.2); font-weight: 300; font-size: 0.48em; vertical-align: middle; margin: 0 10px; }
  .hero h1 .on { color: var(--orange); }
  .hero-sub { font-size: 17px; font-weight: 400; color: rgba(255,255,255,0.4); margin-top: 10px; }
  .progress-bar-wrap { background: rgba(255,255,255,0.1); border-radius: 100px; height: 5px; margin: 22px auto 0; max-width: 420px; overflow: hidden; }
  .progress-bar-fill { height: 5px; border-radius: 100px; background: linear-gradient(90deg, var(--blue), var(--orange)); transition: width 0.35s ease; width: 0%; }
  .progress-label { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.3); margin-top: 8px; letter-spacing: 0.06em; }

  /* ── SCORE ── */
  .score-wrap { display: flex; justify-content: center; gap: 12px; padding: 18px 24px 0; }
  .score-badge { display: flex; align-items: center; gap: 7px; background: #fff; border-radius: 100px; padding: 7px 18px; font-size: 15px; font-weight: 700; box-shadow: 0 2px 8px rgba(0,0,0,0.07); }
  .score-badge .dot { width: 9px; height: 9px; border-radius: 50%; }
  .score-badge.cb .dot { background: var(--correct); }
  .score-badge.wb .dot { background: var(--wrong); }

  /* ── QUESTIONS ── */
  .questions-container { max-width: 840px; margin: 22px auto 60px; padding: 0 18px; display: flex; flex-direction: column; gap: 9px; }
  .section-divider { padding: 8px 0 2px; }
  .section-label { font-size: 11px; font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; color: #bbb; padding-top: 10px; border-top: 1.5px solid #e2e2ec; }

  /* ── CARD ── */
  .q-card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(26,26,46,0.055);
    border: 2px solid transparent;
    transition: border-color 0.25s, background 0.25s;
  }
  .q-card.correct { border-color: var(--correct); background: #f0fdf9; }
  .q-card.wrong   { border-color: var(--wrong);   background: #fff4f4; }

  .card-main { display: flex; gap: 14px; align-items: flex-start; padding: 15px 18px 14px; }

  .q-num { font-size: 14px; font-weight: 800; color: #ccc; width: 26px; flex-shrink: 0; padding-top: 4px; text-align: right; }

  .q-body { flex: 1; display: flex; flex-direction: column; gap: 10px; }

  .q-sentence { font-size: 18px; font-weight: 500; color: var(--dark); line-height: 1.55; }

  /* blank inside sentence */
  .blank-token {
    display: inline-block; min-width: 48px; height: 30px; line-height: 30px;
    text-align: center; border-radius: 6px; border: 2px dashed #ccc;
    background: var(--light); font-size: 14px; font-weight: 800; color: transparent;
    vertical-align: middle; margin: 0 2px; transition: all 0.2s;
  }
  .blank-token.has-in  { border: 2px solid var(--blue);    background: rgba(33,118,255,0.09);  color: var(--blue); }
  .blank-token.has-on  { border: 2px solid var(--orange);  background: rgba(255,145,0,0.09);   color: var(--orange); }
  .blank-token.ok      { border: 2px solid var(--correct); background: rgba(29,211,176,0.11);  color: var(--correct); }
  .blank-token.bad     { border: 2px solid var(--wrong);   background: rgba(239,35,60,0.09);   color: var(--wrong); text-decoration: line-through; }
  .correction { font-size: 13px; font-weight: 800; color: var(--correct); margin-left: 4px; }

  /* toggle buttons */
  .toggle-row { display: flex; gap: 7px; align-items: center; }
  .toggle-btn {
    font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 800;
    border: 2px solid #e0e0eb; border-radius: 8px; background: #fff;
    color: #bbb; padding: 4px 16px; cursor: pointer;
    transition: all 0.15s; letter-spacing: 0.03em;
  }
  .toggle-btn:hover:not(:disabled) { border-color: #aaa; color: #555; }
  .toggle-btn.active-in  { background: var(--blue);   border-color: var(--blue);   color: #fff; }
  .toggle-btn.active-on  { background: var(--orange); border-color: var(--orange); color: #fff; }
  .toggle-btn:disabled   { opacity: 0.45; cursor: default; }

  /* per-card reset row */
  .reset-one-row {
    display: flex;
    justify-content: flex-end;
    padding: 0 18px 12px 58px;
  }
  .reset-one-btn {
    font-family: 'Outfit', sans-serif; font-size: 12px; font-weight: 700;
    border: 1.5px solid #e0e0eb; border-radius: 100px; background: #fff;
    color: #aaa; padding: 4px 14px; cursor: pointer; letter-spacing: 0.04em;
    transition: all 0.15s;
  }
  .reset-one-btn:hover { border-color: var(--red); color: var(--red); background: #fff5f5; }

  /* ── ANIMATIONS ── */
  @keyframes popIn {
    0%   { transform: scale(0.85); opacity: 0.4; }
    60%  { transform: scale(1.12); }
    100% { transform: scale(1);    opacity: 1; }
  }
  @keyframes jiggle {
    0%,100% { transform: translateX(0); }
    15%     { transform: translateX(-6px) rotate(-1.5deg); }
    35%     { transform: translateX(6px)  rotate(1.5deg); }
    55%     { transform: translateX(-4px) rotate(-1deg); }
    75%     { transform: translateX(4px)  rotate(1deg); }
  }
  .anim-pop    { animation: popIn   0.28s cubic-bezier(0.22,1,0.36,1) both; }
  .anim-jiggle { animation: jiggle  0.45s ease both; }

  /* ── EXPLANATION PANEL ── */
  .explain-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 18px 0 58px; cursor: pointer; user-select: none;
    border-top: 1px solid rgba(0,0,0,0.05);
    background: transparent; transition: background 0.15s;
    min-height: 0; overflow: hidden;
    max-height: 0; /* hidden until answered */
    transition: max-height 0.3s ease, padding 0.3s ease;
  }
  .q-card.answered .explain-bar {
    max-height: 44px;
    padding-top: 9px;
    padding-bottom: 9px;
  }
  .explain-bar:hover { background: rgba(0,0,0,0.025); }
  .explain-trigger {
    font-size: 13px; font-weight: 700; color: var(--grey); letter-spacing: 0.03em;
    display: flex; align-items: center; gap: 6px;
  }
  .explain-trigger .chevron {
    display: inline-block; font-size: 11px; transition: transform 0.22s;
    color: var(--grey);
  }
  .explain-bar.open .chevron { transform: rotate(180deg); }

  .explain-panel {
    max-height: 0; overflow: hidden;
    transition: max-height 0.32s ease, padding 0.32s ease;
    padding: 0 18px 0 58px;
    background: rgba(0,0,0,0.018);
  }
  .explain-panel.open {
    max-height: 200px;
    padding-top: 12px;
    padding-bottom: 14px;
  }
  .explain-text {
    font-size: 15px; font-weight: 400; color: #444; line-height: 1.6;
  }
  .explain-text strong { font-weight: 700; color: var(--dark); }
  .explain-text .rule-tag {
    display: inline-block; font-size: 11px; font-weight: 800; letter-spacing: 0.1em;
    text-transform: uppercase; border-radius: 5px; padding: 2px 8px; margin-right: 6px;
    vertical-align: middle;
  }
  .explain-text .rule-tag.in  { background: rgba(33,118,255,0.12);  color: var(--blue); }
  .explain-text .rule-tag.on  { background: rgba(255,145,0,0.14);   color: #cc6a00; }

  /* ── ACTIONS ── */
  .actions { display: flex; justify-content: center; gap: 12px; padding: 0 18px 18px; max-width: 840px; margin: 0 auto; flex-wrap: wrap; }
  .btn { font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 700; border: none; border-radius: 100px; padding: 12px 30px; cursor: pointer; transition: all 0.18s; }
  .btn-reset { background: #fff; color: var(--dark); border: 2px solid #e0e0eb; }
  .btn-reset:hover { border-color: var(--dark); }
  .btn-check { background: var(--dark); color: #fff; }
  .btn-check:hover { background: var(--mid); transform: translateY(-2px); box-shadow: 0 6px 18px rgba(26,26,46,0.18); }

  /* ── RESULTS ── */
  .results-screen { display: none; max-width: 480px; margin: 28px auto 60px; padding: 0 18px; text-align: center; }
  .results-screen.visible { display: block; }
  .result-card { background: #fff; border-radius: 24px; padding: 40px 32px; box-shadow: 0 8px 40px rgba(26,26,46,0.1); }
  .result-emoji { font-size: 60px; margin-bottom: 12px; }
  .result-score { font-size: 72px; font-weight: 900; letter-spacing: -0.05em; line-height: 1; margin-bottom: 6px; }
  .result-label { font-size: 16px; color: var(--grey); margin-bottom: 24px; }
  .result-breakdown { display: flex; gap: 10px; justify-content: center; margin-bottom: 24px; }
  .breakdown-pill { border-radius: 100px; padding: 8px 20px; font-size: 15px; font-weight: 700; }
  .breakdown-pill.c { background: rgba(29,211,176,0.13); color: var(--correct); }
  .breakdown-pill.w { background: rgba(239,35,60,0.1);   color: var(--wrong); }

  @media (max-width: 520px) {
    .site-header { padding: 16px 16px; }
    .q-sentence { font-size: 16px; }
    .toggle-btn { font-size: 13px; padding: 4px 13px; }
    .explain-panel, .explain-bar { padding-left: 42px; }
  }
</style>
</head>
<body>

<header class="site-header">
  <div class="logo">John<span>Plus</span>English</div>
  <div class="brand-dots"><span></span><span></span><span></span></div>
</header>

<div class="hero">
  <h1><span class="in">IN</span><span class="or">or</span><span class="on">ON</span></h1>
  <p class="hero-sub">Choose IN or ON — instant feedback on every answer.</p>
  <div class="progress-bar-wrap"><div class="progress-bar-fill" id="progressBar"></div></div>
  <p class="progress-label" id="progressLabel">0 / 99 answered</p>
</div>

<div class="score-wrap">
  <div class="score-badge cb"><span class="dot"></span><span id="scoreCorrect">0</span> correct</div>
  <div class="score-badge wb"><span class="dot"></span><span id="scoreWrong">0</span> wrong</div>
</div>

<div class="questions-container" id="questionsContainer"></div>

<div class="actions">
  <button class="btn btn-reset" onclick="resetAll()">Reset</button>
</div>

<div class="results-screen" id="resultsScreen">
  <div class="result-card">
    <div class="result-emoji" id="resultEmoji">🎉</div>
    <div class="result-score" id="resultScore">—</div>
    <div class="result-label"  id="resultLabel"></div>
    <div class="result-breakdown">
      <div class="breakdown-pill c" id="breakCorrect">—</div>
      <div class="breakdown-pill w" id="breakWrong">—</div>
    </div>
    <button class="btn btn-check" onclick="resetAll()">Try again</button>
  </div>
</div>

<script>
// ─── DATA ───────────────────────────────────────────────────────────────────
// Each question: pre, post, answer ("in"/"on"), group, explanation
const questions = [
  // TIME EXPRESSIONS
  { pre:"Could you come", post:"Friday?", answer:"on", group:"Time expressions",
    exp:`<span class="rule-tag on">ON</span> Use <strong>on</strong> with specific days and dates: <em>on Friday, on Monday, on 3rd June</em>.` },
  { pre:"Sure!", post:"the morning or the afternoon?", answer:"in", group:"Time expressions",
    exp:`<span class="rule-tag in">IN</span> Use <strong>in</strong> with parts of the day: <em>in the morning, in the afternoon, in the evening</em>. (Exception: <em>at night, at noon</em>.)` },
  { pre:"", post:"the evening if you can, but not at night.", answer:"in", group:"Time expressions",
    exp:`<span class="rule-tag in">IN</span> <strong>in the evening</strong> — same rule as morning/afternoon. Note the contrast with <em>at night</em>, which uses <strong>at</strong>.` },
  { pre:"Julia turns 25", post:"a few days.", answer:"in", group:"Time expressions",
    exp:`<span class="rule-tag in">IN</span> Use <strong>in</strong> for future periods: <em>in a few days, in a week, in a moment</em>.` },
  { pre:"I thought her birthday is", post:"August.", answer:"in", group:"Time expressions",
    exp:`<span class="rule-tag in">IN</span> Use <strong>in</strong> with months, years, seasons, and centuries: <em>in August, in 2024, in summer, in the 20th century</em>.` },
  { pre:"I hope to see you", post:"summer.", answer:"in", group:"Time expressions",
    exp:`<span class="rule-tag in">IN</span> Seasons take <strong>in</strong>: <em>in spring, in summer, in autumn, in winter</em>.` },
  { pre:"", post:"what decade was he born?", answer:"in", group:"Time expressions",
    exp:`<span class="rule-tag in">IN</span> Decades and centuries take <strong>in</strong>: <em>in the 1990s, in what decade, in the 20th century</em>.` },
  { pre:"I was born", post:"1985.", answer:"in", group:"Time expressions",
    exp:`<span class="rule-tag in">IN</span> Years take <strong>in</strong>: <em>in 1985, in 2001</em>. Think of the year as a container of time.` },
  { pre:"", post:"the 20th century, of course.", answer:"in", group:"Time expressions",
    exp:`<span class="rule-tag in">IN</span> Centuries take <strong>in</strong>: <em>in the 20th century, in the Middle Ages</em>.` },

  // PLACE
  { pre:"She grew up", post:"my town.", answer:"in", group:"Place",
    exp:`<span class="rule-tag in">IN</span> Use <strong>in</strong> for enclosed or bounded spaces — towns, cities, countries, rooms: <em>in London, in the office, in my town</em>.` },
  { pre:"It's located", post:"the south of the country.", answer:"in", group:"Place",
    exp:`<span class="rule-tag in">IN</span> Regions and areas within a place take <strong>in</strong>: <em>in the south, in the north-east, in the centre</em>.` },
  { pre:"It's not inland, it's", post:"the coast.", answer:"on", group:"Place",
    exp:`<span class="rule-tag on">ON</span> Use <strong>on</strong> for linear or surface locations: <em>on the coast, on the border, on the river, on the edge</em>.` },
  { pre:"Oh, I thought you lived", post:"an island.", answer:"on", group:"Place",
    exp:`<span class="rule-tag on">ON</span> Islands take <strong>on</strong>: <em>on an island, on Cuba, on the Isle of Man</em>. Think of it as being on top of a landmass in water.` },
  { pre:"Not now though,", post:"the past.", answer:"in", group:"Place",
    exp:`<span class="rule-tag in">IN</span> Time periods viewed as containers take <strong>in</strong>: <em>in the past, in the future, in those days, in my youth</em>.` },
  { pre:"Did you live", post:"the suburbs?", answer:"in", group:"Place",
    exp:`<span class="rule-tag in">IN</span> Residential areas with a sense of enclosure take <strong>in</strong>: <em>in the suburbs, in the city centre, in the countryside</em>.` },
  { pre:"No, I used to live", post:"the outskirts.", answer:"on", group:"Place",
    exp:`<span class="rule-tag on">ON</span> The outskirts are viewed as a boundary or edge, so they take <strong>on</strong>: <em>on the outskirts, on the periphery</em>. Contrast with <em>in the suburbs</em>.` },
  { pre:"And I may even move abroad", post:"the future.", answer:"in", group:"Place",
    exp:`<span class="rule-tag in">IN</span> <em>in the future / in the past</em> — time periods treated as containers always take <strong>in</strong>.` },

  // MIND
  { pre:"Do you have any particular place", post:"mind?", answer:"in", group:"Mind / thought",
    exp:`<span class="rule-tag in">IN</span> <strong>have something in mind</strong> = be considering it. The mind is treated as a mental space or container.` },
  { pre:"You look worried, what's", post:"your mind?", answer:"on", group:"Mind / thought",
    exp:`<span class="rule-tag on">ON</span> <strong>on your mind</strong> = something you're actively thinking or worrying about. <em>On</em> suggests it's weighing on you, sitting on top of your thoughts.` },

  // MEDIA
  { pre:"I heard the news", post:"the radio.", answer:"on", group:"Media",
    exp:`<span class="rule-tag on">ON</span> Broadcast media take <strong>on</strong>: <em>on the radio, on TV, on the news, on a podcast</em>. Think of the signal being transmitted on a channel.` },
  { pre:"I saw it", post:"TV last night.", answer:"on", group:"Media",
    exp:`<span class="rule-tag on">ON</span> <strong>on TV</strong> — same rule as radio. Note: no article with <em>TV</em> in this sense (<em>on TV</em>, not <em>on the TV</em> — though both are heard).` },
  { pre:"Was it", post:"the 10 o'clock news? (TV programme)", answer:"on", group:"Media",
    exp:`<span class="rule-tag on">ON</span> A specific programme you can watch/listen to takes <strong>on</strong>: <em>on the news, on a chat show, on the radio</em>.` },
  { pre:"He's been", post:"the news a lot recently. (topical)", answer:"in", group:"Media",
    exp:`<span class="rule-tag in">IN</span> <strong>in the news</strong> = being discussed as a news topic. <strong>on the news</strong> = appearing on a news broadcast. Subtle but important difference.` },
  { pre:"I saw his photo", post:"the front page of today's newspaper.", answer:"on", group:"Media",
    exp:`<span class="rule-tag on">ON</span> A page is a surface, so use <strong>on</strong>: <em>on the front page, on page 3, on the cover</em>.` },
  { pre:"I read it", post:"a newspaper.", answer:"in", group:"Media",
    exp:`<span class="rule-tag in">IN</span> A newspaper/magazine is a container: <em>in a newspaper, in a magazine, in a book, in an article</em>.` },
  { pre:"It was", post:"an article.", answer:"in", group:"Media",
    exp:`<span class="rule-tag in">IN</span> Articles, chapters, and sections are containers: <em>in an article, in a chapter, in a report</em>.` },
  { pre:"I've come across so many new words", post:"this book.", answer:"in", group:"Media",
    exp:`<span class="rule-tag in">IN</span> Books are containers for content: <em>in this book, in the novel, in the manual</em>. But the physical surface: <em>on the cover, on the spine</em>.` },
  { pre:"What's written", post:"the cover?", answer:"on", group:"Media",
    exp:`<span class="rule-tag on">ON</span> The cover is a surface: <em>on the cover, on the label, on the screen, on the page</em>.` },
  { pre:"It's right there,", post:"the screen.", answer:"on", group:"Media",
    exp:`<span class="rule-tag on">ON</span> Screens and surfaces: <em>on the screen, on the monitor, on the wall, on the page</em>.` },

  // FIXED PHRASES
  { pre:"I can't talk right now, I'm", post:"a hurry/rush.", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in a hurry / in a rush</strong>. Think of being caught inside a state of urgency.` },
  { pre:"Are you", post:"a diet or what?", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on a diet</strong>. Similarly: <em>on a course, on a programme, on a plan</em> — following a prescribed regimen.` },
  { pre:"I'm", post:"my/the way, see you in 5 mins. (coming)", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> <strong>on my way</strong> = in the process of travelling there. The journey is a route you are on.` },
  { pre:"Move! You're", post:"my/the way and I can't see the TV. (blocking)", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> <strong>in the way</strong> = blocking/obstructing. Contrast with <em>on the way</em> = travelling. Two very different meanings!` },
  { pre:"", post:"a way, I agree with you.", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in a way</strong> = to some extent, partially. Also: <em>in some ways, in many ways</em>.` },
  { pre:"Face masks were", post:"demand in 2020. (popular/wanted)", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> <strong>in demand</strong> = widely wanted/needed. Fixed phrase — don't confuse with <em>on demand</em>.` },
  { pre:"Netflix allows you to watch TV shows", post:"demand. (when you wish)", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> <strong>on demand</strong> = available whenever you want it. These two are a classic minimal pair: <em>in demand</em> (popular) vs <em>on demand</em> (available on request).` },
  { pre:"Don't leave this place", post:"a mess.", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in a mess</strong> — also <em>in chaos, in disorder, in ruins, in pieces</em>. These describe a state of disorder you are "inside".` },
  { pre:"I'll help you", post:"condition that you return the favour.", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on condition that</strong> = provided that, only if. Also: <em>on the condition that, on one condition</em>.` },
  { pre:"I have to work 7 days", post:"a row.", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in a row</strong> = consecutively, one after another. Also: <em>three times in a row, five days in a row</em>.` },
  { pre:"Are you", post:"good terms with your boss?", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on good terms (with)</strong> = having a good relationship. Also: <em>on bad terms, on speaking terms, on first-name terms</em>.` },
  { pre:"We should book", post:"advance in case it's busy.", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in advance</strong> = ahead of time, beforehand.` },
  { pre:"I don't stay", post:"bed when I wake up.", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> <strong>in bed</strong> = under the covers, lying in the bed (inside it). Contrast: <em>on the bed</em> = sitting/lying on top of the bed (on the surface).` },
  { pre:"Don't sit", post:"the bed! I've just made it.", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> <strong>on the bed</strong> = on the surface of the bed without getting under the covers. Contrast: <em>in bed</em> = under the duvet.` },
  { pre:"I didn't do it", post:"purpose.", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on purpose</strong> = deliberately, intentionally. The opposite is <em>by accident / by mistake</em> (using <em>by</em>).` },
  { pre:"I'm not", post:"favour of such changes.", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in favour of</strong> = supporting, agreeing with. <em>Against</em> is simply <em>against</em>, not a preposition swap.` },
  { pre:"His success was never", post:"doubt.", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in doubt</strong> = uncertain. Also: <em>without doubt, beyond doubt, no doubt</em>. When something is unclear, it's "inside" a state of doubt.` },
  { pre:"He's been arrested", post:"suspicion of theft.", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on suspicion of</strong> = because there is suspicion, without proof yet. Legal/police language.` },
  { pre:"Teachers are", post:"strike over recent pay cuts.", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on strike</strong> = actively refusing to work. Also: <em>go on strike, call a strike</em>.` },
  { pre:"Who's", post:"charge here?", answer:"in", group:"Fixed phrases",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in charge</strong> = responsible, in control. Also: <em>in charge of something, take charge, be in charge</em>.` },
  { pre:"Put your phone", post:"silent.", answer:"on", group:"Fixed phrases",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on silent / on vibrate / on airplane mode</strong> — phone/device settings use <em>on</em>, like switching to a mode.` },

  // VERBS & COLLOCATIONS
  { pre:"I've invested money", post:"the stock market.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>invest in</strong> — you put money into something. Also: <em>invest in property, invest in a company, invest in yourself</em>.` },
  { pre:"She's experienced", post:"the field of business.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>experienced in</strong> — knowledge/skill within a field. Similarly: <em>qualified in, skilled in, trained in, specialised in</em>.` },
  { pre:"I studied a degree", post:"education.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> Academic fields use <strong>in</strong>: <em>a degree in law, a Masters in linguistics, a PhD in biology</em>.` },
  { pre:"I need some lessons", post:"how to build a website.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>lessons in</strong> = instruction covering a topic: <em>lessons in grammar, lessons in cooking, a course in photography</em>.` },
  { pre:"I had no difficulty", post:"answering the question.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>difficulty in (doing)</strong> — the gerund follows. Also: <em>no trouble in, no problem in</em>. Note: many speakers omit the preposition entirely in informal speech.` },
  { pre:"He insisted", post:"paying for lunch.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>insist on (doing)</strong> — fixed collocation. Also: <em>insist on silence, insist on quality</em>.` },
  { pre:"I'm working", post:"a new novel.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>work on</strong> = be in the process of creating/developing something: <em>work on a project, work on your accent, work on a problem</em>.` },
  { pre:"Don't put the blame", post:"me.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>put/place the blame on</strong> someone. Also: <em>shift the blame onto, blame someone for</em>. Blame lands on a person.` },
  { pre:"Spain is rich", post:"history.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>rich in</strong> = having a lot of: <em>rich in culture, rich in minerals, rich in flavour</em>.` },
  { pre:"I take no pleasure", post:"killing you, Mr Bond.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>take pleasure in (doing)</strong> — fixed collocation. Also: <em>take pride in, take interest in, take delight in</em>.` },
  { pre:"Were you involved", post:"the decision-making process?", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>involved in</strong> — you are part of something from the inside: <em>involved in a project, involved in a crime, involved in politics</em>.` },
  { pre:"She made an immediate impression", post:"me.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>make an impression on</strong> someone — the impression lands on the person. Also: <em>have an impact on, have an effect on</em>.` },
  { pre:"It has had a huge impact", post:"all of us.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>impact on / effect on / influence on</strong> — these all take <em>on</em>. The force of the impact hits the target.` },
  { pre:"He refused to comment", post:"the allegations.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>comment on</strong> = give an opinion about: <em>comment on the situation, comment on a post</em>.` },
  { pre:"I specialised", post:"philology during my final year.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>specialise in</strong> — you go deeply inside a subject: <em>specialise in tax law, specialise in baroque music</em>.` },
  { pre:"There should be a widespread ban", post:"bullfighting.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>a ban on</strong> something: <em>a ban on smoking, impose a ban on, lift a ban on</em>.` },
  { pre:"We can all agree", post:"that.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>agree on</strong> a specific point or decision. Note: <em>agree with</em> a person or opinion; <em>agree on</em> a plan or fact.` },
  { pre:"You have poor taste", post:"men.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>taste in</strong> = preference/judgement within a category: <em>taste in music, taste in fashion, taste in food</em>.` },
  { pre:"Heavy rain resulted", post:"flooding.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>result in</strong> = cause/lead to an outcome: <em>result in failure, result in success</em>. Contrast: <em>result from</em> = be caused by.` },
  { pre:"You just cannot rely", post:"public transport here.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>rely on / depend on / count on</strong> — trust lands on the thing you depend on.` },
  { pre:"He spends a lot of money", post:"clothes.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>spend (money/time) on</strong> something: <em>spend money on food, spend time on a project, splash out on a holiday</em>.` },
  { pre:"I live", post:"the second floor.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> Floors of a building take <strong>on</strong>: <em>on the ground floor, on the third floor</em>. Think of each floor as a surface.` },
  { pre:"Please, focus", post:"what you are doing.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>focus on / concentrate on / work on</strong> — your attention lands on the target.` },
  { pre:"", post:"the first picture, we see ...", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> When describing what is depicted inside an image: <em>in the picture, in the photo, in the image, in the diagram</em>.` },
  { pre:"Crime is", post:"the increase.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on the increase/decrease/rise/decline</strong>. These are trends that you are "on" (like being on a slope).` },
  { pre:"Is the new iPhone", post:"sale yet?", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>on sale</strong> = available to buy. Note the difference: <em>for sale</em> = being sold by an owner. <em>On sale</em> also sometimes means reduced in price.` },
  { pre:"", post:"average, how many hours do you sleep?", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on average</strong> = typically, as a mean. Also: <em>on the whole, on balance, on the contrary</em> — evaluative adverbials.` },
  { pre:"I'd love to come to your party, count me", post:".", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>count me in</strong> = include me. Contrast: <em>count me out</em> = exclude me. The <em>in/out</em> here is directional.` },
  { pre:"I'm counting", post:"your support.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>count on / rely on</strong> = depend on. Your trust is placed on that person.` },
  { pre:"I love when those flowers are", post:"bloom.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> Fixed phrase: <strong>in bloom</strong> = flowering. Also: <em>in blossom, in full bloom</em>. These describe a state you're inside.` },
  { pre:"We'd better hurry as we're", post:"danger of missing our flight.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>in danger of</strong> = at risk of. You're "inside" a dangerous situation: <em>in danger of losing, in danger of collapse</em>.` },
  { pre:"She's", post:"maternity leave.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> Leave types take <strong>on</strong>: <em>on maternity leave, on paternity leave, on sick leave, on annual leave, on holiday</em>.` },
  { pre:"I'm", post:"holiday at the moment.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>on holiday / on vacation</strong> — British English uses <em>holiday</em>. Think of being "on" a break from work.` },
  { pre:"The book describes the war", post:"great detail.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>in detail / in great detail</strong> — level of description is a container: <em>explain in detail, describe in depth, analyse in full</em>.` },
  { pre:"Buses here never arrive", post:"time. (not late)", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>on time</strong> = punctually, neither early nor late. It's the scheduled time you arrive <em>on</em>.` },
  { pre:"You're just", post:"time for lunch. (early enough)", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>in time</strong> = early enough to do something before a deadline. The classic pair: <em>on time</em> (punctual) vs <em>in time</em> (with time to spare).` },
  { pre:"I've kept it", post:"good condition.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> States/conditions use <strong>in</strong>: <em>in good condition, in bad shape, in perfect order, in poor health, in pieces</em>.` },
  { pre:"Shh! I'm", post:"the phone.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>on the phone</strong> = currently in a phone call. Also: <em>on the line, on a call, on Zoom</em>.` },
  { pre:"The word is", post:"the tip of my tongue.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on the tip of my tongue</strong> = almost remembered. The word sits on the very tip — a surface image.` },
  { pre:"The TV is", post:"the corner of the living room. (inside)", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>in the corner</strong> = inside a room, at the point where two walls meet (interior corner). Contrast: <em>on the corner</em> = at a street intersection (exterior).` },
  { pre:"I'll meet you", post:"the corner by the post office. (outside)", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> <strong>on the corner</strong> = at a street corner outside. Contrast with <em>in the corner</em> of a room. Classic minimal pair!` },
  { pre:"We're seeing a rise", post:"global temperatures.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>a rise/fall/increase/decrease in</strong> something — the change is happening within a measurement: <em>a rise in prices, a drop in standards</em>.` },
  { pre:"", post:"behalf of the team, I'd like to thank our coach.", answer:"on", group:"Verbs & collocations",
    exp:`<span class="rule-tag on">ON</span> Fixed phrase: <strong>on behalf of</strong> = representing, acting for: <em>speak on behalf of, sign on behalf of, thank you on behalf of</em>.` },
  { pre:"He got upset and left the classroom", post:"tears.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>in tears</strong> = crying. Emotional states as containers: <em>in tears, in pain, in shock, in despair, in fits of laughter</em>.` },
  { pre:"I've been", post:"this queue for ages.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>in a queue/line</strong> — you are part of the queue, enclosed within it. British English: <em>queue</em>; American English: <em>line</em>.` },
  { pre:"I'm deaf", post:"one ear, would you mind speaking up?", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> Body parts as locations use <strong>in</strong>: <em>deaf in one ear, blind in one eye, a pain in my knee, a ringing in my ears</em>.` },
  { pre:"Is it included", post:"the price?", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>included in</strong> = part of, contained within: <em>included in the price, included in the package, included in the deal</em>.` },
  { pre:"He has very little confidence", post:"himself.", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>confidence in</strong> = belief in the ability/reliability of: <em>confidence in yourself, trust in the system, faith in the process</em>.` },
  { pre:"Do you believe", post:"god?", answer:"in", group:"Verbs & collocations",
    exp:`<span class="rule-tag in">IN</span> <strong>believe in</strong> = have faith in the existence or value of something: <em>believe in god, believe in yourself, believe in second chances</em>.` },
];

// ─── STATE ───────────────────────────────────────────────────────────────────
let userAnswers  = Array(questions.length).fill(null); // null | "in" | "on"
let answerState  = Array(questions.length).fill(null); // null | "correct" | "wrong"
let expandedExp  = Array(questions.length).fill(false);

let scoreCorrect = 0;
let scoreWrong   = 0;

// ─── RENDER ──────────────────────────────────────────────────────────────────
function renderQuestions() {
  const container = document.getElementById('questionsContainer');
  container.innerHTML = '';
  let currentGroup = '';

  questions.forEach((q, i) => {
    if (q.group !== currentGroup) {
      currentGroup = q.group;
      const div = document.createElement('div');
      div.className = 'section-divider';
      div.innerHTML = `<div class="section-label">${currentGroup}</div>`;
      container.appendChild(div);
    }

    const ans   = userAnswers[i];
    const state = answerState[i];

    const tokClass = state === 'correct' ? 'ok'
                   : state === 'wrong'   ? 'bad'
                   : ans ? (ans === 'in' ? 'has-in' : 'has-on') : '';
    const tokText = ans ? ans.toUpperCase() : '';

    const corrText = (state === 'wrong') ? '→ ' + q.answer.toUpperCase() : '';

    const cardClass = state === 'correct' ? 'q-card correct answered'
                    : state === 'wrong'   ? 'q-card wrong answered'
                    : ans                 ? 'q-card answered'
                    : 'q-card';

    const inDisabled  = state !== null ? 'disabled' : '';
    const onDisabled  = state !== null ? 'disabled' : '';
    const inActive    = ans === 'in'   ? 'active-in' : '';
    const onActive    = ans === 'on'   ? 'active-on' : '';

    const expOpen = expandedExp[i] ? 'open' : '';

    const sentence = `${q.pre ? q.pre + ' ' : ''}<span class="blank-token ${tokClass}" id="tok-${i}">${tokText}</span><span class="correction" id="corr-${i}">${corrText}</span> ${q.post}`;

    const card = document.createElement('div');
    card.className = cardClass;
    card.id = `card-${i}`;
    card.innerHTML = `
      <div class="card-main">
        <div class="q-num">${i + 1}</div>
        <div class="q-body">
          <div class="q-sentence">${sentence}</div>
          <div class="toggle-row" id="trow-${i}">
            <button class="toggle-btn ${inActive}" id="btn-in-${i}" onclick="pick(${i},'in')" ${inDisabled}>IN</button>
            <button class="toggle-btn ${onActive}" id="btn-on-${i}" onclick="pick(${i},'on')" ${onDisabled}>ON</button>
          </div>
        </div>
      </div>
      <div class="explain-bar ${expOpen}" id="expbar-${i}" onclick="toggleExplain(${i})">
        <span class="explain-trigger">
          <span class="chevron">▼</span> Why?
        </span>
      </div>
      <div class="explain-panel ${expOpen}" id="exppanel-${i}">
        <div class="explain-text">${q.exp}</div>
      </div>
      ${state !== null ? `<div class="reset-one-row"><button class="reset-one-btn" onclick="resetOne(${i})">↺ Try again</button></div>` : ''}
    `;
    container.appendChild(card);
  });
}

// ─── PICK ────────────────────────────────────────────────────────────────────
function pick(i, choice) {
  if (answerState[i] !== null) return; // already answered

  userAnswers[i] = choice;
  const correct  = choice === questions[i].answer;
  answerState[i] = correct ? 'correct' : 'wrong';

  if (correct) scoreCorrect++;
  else         scoreWrong++;

  // update score display
  document.getElementById('scoreCorrect').textContent = scoreCorrect;
  document.getElementById('scoreWrong').textContent   = scoreWrong;

  // update card visuals
  const card   = document.getElementById(`card-${i}`);
  const tok    = document.getElementById(`tok-${i}`);
  const corr   = document.getElementById(`corr-${i}`);
  const btnIn  = document.getElementById(`btn-in-${i}`);
  const btnOn  = document.getElementById(`btn-on-${i}`);

  // disable both buttons
  btnIn.disabled = true;
  btnOn.disabled = true;

  if (correct) {
    card.classList.add('correct', 'answered');
    tok.className = 'blank-token ok anim-pop';
    tok.textContent = choice.toUpperCase();
  } else {
    card.classList.add('wrong', 'answered');
    tok.className = 'blank-token bad anim-jiggle';
    tok.textContent = choice.toUpperCase();
    corr.textContent = '→ ' + questions[i].answer.toUpperCase();
  }

  // remove animation class after it finishes so re-renders work
  tok.addEventListener('animationend', () => {
    tok.classList.remove('anim-pop', 'anim-jiggle');
  }, { once: true });

  // add ↺ Try again button below the card
  const resetRow = document.createElement('div');
  resetRow.className = 'reset-one-row';
  resetRow.id = `resetrow-${i}`;
  resetRow.innerHTML = `<button class="reset-one-btn" onclick="resetOne(${i})">↺ Try again</button>`;
  card.appendChild(resetRow);

  updateProgress();
  checkCompletion();
}

// ─── EXPLAIN ─────────────────────────────────────────────────────────────────
function toggleExplain(i) {
  expandedExp[i] = !expandedExp[i];
  document.getElementById(`expbar-${i}`).classList.toggle('open', expandedExp[i]);
  document.getElementById(`exppanel-${i}`).classList.toggle('open', expandedExp[i]);
}

// ─── PROGRESS ────────────────────────────────────────────────────────────────
function updateProgress() {
  const answered = answerState.filter(a => a !== null).length;
  document.getElementById('progressBar').style.width = (answered / questions.length * 100) + '%';
  document.getElementById('progressLabel').textContent = `${answered} / ${questions.length} answered`;
}

// ─── COMPLETION ──────────────────────────────────────────────────────────────
function checkCompletion() {
  if (answerState.filter(a => a !== null).length < questions.length) return;

  const pct    = Math.round(scoreCorrect / questions.length * 100);
  const emoji  = pct === 100 ? '🏆' : pct >= 80 ? '🎉' : pct >= 60 ? '👍' : '📚';
  const label  = pct === 100 ? 'Perfect score!' : pct >= 80 ? 'Excellent work!' : pct >= 60 ? 'Good effort — review the ones you missed.' : 'Keep practising!';
  const colour = pct >= 80 ? 'var(--blue)' : pct >= 60 ? 'var(--orange)' : 'var(--red)';

  document.getElementById('resultEmoji').textContent   = emoji;
  document.getElementById('resultScore').textContent   = pct + '%';
  document.getElementById('resultScore').style.color   = colour;
  document.getElementById('resultLabel').textContent   = label;
  document.getElementById('breakCorrect').textContent  = scoreCorrect + ' correct';
  document.getElementById('breakWrong').textContent    = scoreWrong + ' wrong';

  const rs = document.getElementById('resultsScreen');
  rs.classList.add('visible');
  setTimeout(() => rs.scrollIntoView({ behavior: 'smooth' }), 200);
}

// ─── RESET ONE ───────────────────────────────────────────────────────────────
function resetOne(i) {
  const wasCorrect = answerState[i] === 'correct';
  const wasWrong   = answerState[i] === 'wrong';

  if (wasCorrect) scoreCorrect = Math.max(0, scoreCorrect - 1);
  if (wasWrong)   scoreWrong   = Math.max(0, scoreWrong - 1);

  userAnswers[i]  = null;
  answerState[i]  = null;
  expandedExp[i]  = false;

  document.getElementById('scoreCorrect').textContent = scoreCorrect;
  document.getElementById('scoreWrong').textContent   = scoreWrong;

  // Re-render just this card by rebuilding it
  const q   = questions[i];
  const card = document.getElementById(`card-${i}`);
  card.className = 'q-card';
  card.innerHTML = `
    <div class="card-main">
      <div class="q-num">${i + 1}</div>
      <div class="q-body">
        <div class="q-sentence">${q.pre ? q.pre + ' ' : ''}<span class="blank-token" id="tok-${i}"></span><span class="correction" id="corr-${i}"></span> ${q.post}</div>
        <div class="toggle-row" id="trow-${i}">
          <button class="toggle-btn" id="btn-in-${i}" onclick="pick(${i},'in')">IN</button>
          <button class="toggle-btn" id="btn-on-${i}" onclick="pick(${i},'on')">ON</button>
        </div>
      </div>
    </div>
    <div class="explain-bar" id="expbar-${i}" onclick="toggleExplain(${i})">
      <span class="explain-trigger"><span class="chevron">▼</span> Why?</span>
    </div>
    <div class="explain-panel" id="exppanel-${i}">
      <div class="explain-text">${q.exp}</div>
    </div>
  `;
  updateProgress();
}

// ─── RESET ───────────────────────────────────────────────────────────────────
function resetAll() {
  userAnswers  = Array(questions.length).fill(null);
  answerState  = Array(questions.length).fill(null);
  expandedExp  = Array(questions.length).fill(false);
  scoreCorrect = 0;
  scoreWrong   = 0;
  document.getElementById('scoreCorrect').textContent = '0';
  document.getElementById('scoreWrong').textContent   = '0';
  document.getElementById('resultsScreen').classList.remove('visible');
  updateProgress();
  renderQuestions();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ─── INIT ────────────────────────────────────────────────────────────────────
renderQuestions();
updateProgress();
</script>
</body>
</html>

<script>
  // ── SCROLL REVEAL ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.timeline-entry, .god-card, .myth-card').forEach(el => observer.observe(el));

  // Stagger god cards
  document.querySelectorAll('.god-card').forEach((el, i) => {
    el.style.transitionDelay = (i * 0.07) + 's';
  });

  // ── QUIZ ──
  const questions = [
    {
      q: "Athens is named after which goddess?",
      opts: ["Hera", "Aphrodite", "Athena", "Artemis"],
      correct: 2,
      feedback: "Correct! Athena won a contest against Poseidon for patronage of the city by offering an olive tree — more useful than Poseidon's saltwater spring."
    },
    {
      q: "In which century was the Parthenon completed?",
      opts: ["6th century BCE", "5th century BCE", "4th century BCE", "3rd century BCE"],
      correct: 1,
      feedback: "Right! The Parthenon was completed in 432 BCE, in the 5th century BCE, during the Golden Age of Athens under Pericles."
    },
    {
      q: "What was the Agora in ancient Athens?",
      opts: ["A royal palace", "A temple complex", "The main public gathering and marketplace", "A military fortress"],
      correct: 2,
      feedback: "Exactly! The Agora was the civic and commercial heart of Athens — where citizens debated politics, traded goods, and philosophers like Socrates walked and talked."
    },
    {
      q: "Who was Socrates executed by, and how?",
      opts: ["The Persians, by sword", "The Athenians, by hemlock", "The Spartans, in battle", "The gods, by lightning"],
      correct: 1,
      feedback: "Correct. Socrates was condemned by an Athenian jury of 500 citizens for 'corrupting the youth' and forced to drink hemlock poison in 399 BCE."
    },
    {
      q: "What is the literal meaning of 'democracy'?",
      opts: ["Rule by the wise", "Rule by the strong", "Rule by the gods", "Rule by the people"],
      correct: 3,
      feedback: "Yes! From the Greek demos (people) + kratos (power or rule). Athenian democracy only extended to free male citizens, but it was still a revolutionary concept."
    },
    {
      q: "Which hero killed the Minotaur in the Labyrinth?",
      opts: ["Hercules", "Perseus", "Theseus", "Achilles"],
      correct: 2,
      feedback: "Theseus! The Athenian hero entered the Cretan labyrinth, killed the half-bull monster, and escaped by following a thread left by the princess Ariadne."
    },
    {
      q: "Alexander the Great was tutored as a boy by which philosopher?",
      opts: ["Socrates", "Plato", "Aristotle", "Pythagoras"],
      correct: 2,
      feedback: "Aristotle! The philosopher was employed by King Philip II of Macedon to tutor his son Alexander from age 13. It's one of history's great teacher-student pairings."
    },
    {
      q: "The myth of Icarus is traditionally understood as a warning about what?",
      opts: ["The dangers of sea travel", "Hubris — excessive pride and overreaching", "The cruelty of the gods", "Disobeying one's parents"],
      correct: 1,
      feedback: "Hubris — the Greek concept of dangerous overconfidence or excessive pride. Icarus was warned, ignored the warning, and fell. The Greeks saw this as a fundamental human flaw."
    }
  ];

  let current = 0;
  let score = 0;
  let answered = false;

  function loadQuestion() {
    answered = false;
    const q = questions[current];
    document.getElementById('q-text').textContent = q.q;
    document.getElementById('q-counter').textContent = `${current + 1} of ${questions.length}`;
    document.getElementById('q-feedback').textContent = '';
    document.getElementById('q-feedback').classList.remove('show');
    document.getElementById('btn-next').classList.remove('show');

    const opts = document.getElementById('q-options');
    opts.innerHTML = '';
    q.opts.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.className = 'quiz-opt';
      btn.textContent = opt;
      btn.onclick = () => answer(i, btn);
      opts.appendChild(btn);
    });
  }

  function answer(idx, btn) {
    if (answered) return;
    answered = true;
    const q = questions[current];
    const all = document.querySelectorAll('.quiz-opt');

    all.forEach(b => b.disabled = true);

    if (idx === q.correct) {
      btn.classList.add('correct');
      score++;
      document.getElementById('q-feedback').textContent = '✓ ' + q.feedback;
    } else {
      btn.classList.add('wrong');
      all[q.correct].classList.add('correct');
      document.getElementById('q-feedback').textContent = '✗ ' + q.feedback;
    }

    document.getElementById('q-feedback').classList.add('show');

    if (current < questions.length - 1) {
      document.getElementById('btn-next').classList.add('show');
    } else {
      setTimeout(showScore, 1800);
    }
  }

  function nextQuestion() {
    current++;
    loadQuestion();
  }

  function showScore() {
    document.getElementById('quiz-main').style.display = 'none';
    const scoreEl = document.getElementById('quiz-score');
    scoreEl.classList.add('show');
    document.getElementById('score-num').textContent = score + '/' + questions.length;

    const msgs = [
      [0, 3, "The Oracle is unimpressed… but keep exploring!"],
      [4, 5, "Not bad! The philosophers would be cautiously pleased."],
      [6, 7, "Impressive! Socrates would argue you have potential."],
      [8, 8, "Perfect score! You are a true child of Athens, Christine! 🏛️"]
    ];

    let msg = msgs[0][2];
    for (const [lo, hi, m] of msgs) {
      if (score >= lo && score <= hi) { msg = m; break; }
    }
    document.getElementById('score-msg').textContent = msg;
  }

  function restartQuiz() {
    current = 0; score = 0; answered = false;
    document.getElementById('quiz-main').style.display = '';
    document.getElementById('quiz-score').classList.remove('show');
    loadQuestion();
  }

  loadQuestion();
</script>
</body>
</html>

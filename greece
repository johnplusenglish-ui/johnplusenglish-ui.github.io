<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Christine's Guide to Ancient Greece</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;600;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
<style>
  :root {
    --papyrus: #f5e6c8;
    --papyrus-dark: #e8d5a3;
    --terracotta: #c0522a;
    --terracotta-light: #d4724a;
    --marble: #f0ece4;
    --marble-dark: #d8d0c0;
    --gold: #c8920a;
    --gold-light: #e8b830;
    --aegean: #1a5c7a;
    --aegean-light: #2a7a9e;
    --ink: #2a1f0e;
    --smoke: #8a7a60;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--papyrus);
    color: var(--ink);
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 18px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 2rem;
    position: relative;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(200,146,10,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 20% 100%, rgba(192,82,42,0.1) 0%, transparent 60%),
      linear-gradient(180deg, #f5e6c8 0%, #ede0c0 100%);
    overflow: hidden;
  }

  .hero-columns {
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    height: 220px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 0 5vw;
    pointer-events: none;
    opacity: 0.12;
  }
  .column {
    width: 28px;
    background: linear-gradient(180deg, var(--marble-dark) 0%, var(--smoke) 100%);
    border-radius: 3px 3px 0 0;
  }
  .column::before {
    content: '';
    display: block;
    width: 38px;
    height: 14px;
    background: var(--smoke);
    border-radius: 2px;
    margin-left: -5px;
    margin-bottom: 2px;
  }
  .column::after {
    content: '';
    display: block;
    width: 38px;
    height: 10px;
    background: var(--marble-dark);
    border-radius: 0 0 2px 2px;
    margin-left: -5px;
  }

  .hero-eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    color: var(--terracotta);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .hero h1 {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 0.4rem;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.4s forwards;
  }

  .hero h1 span {
    color: var(--terracotta);
    display: block;
  }

  .hero-subtitle {
    font-family: 'Cinzel', serif;
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--gold);
    letter-spacing: 0.12em;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.6s forwards;
  }

  .hero-dedication {
    font-style: italic;
    font-size: 1.1rem;
    color: var(--smoke);
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.8s forwards;
  }

  .hero-dedication strong { color: var(--terracotta); font-style: normal; }

  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.9s ease 1.2s forwards;
  }
  .scroll-hint span {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--smoke);
    text-transform: uppercase;
  }
  .scroll-arrow {
    width: 2px;
    height: 40px;
    background: linear-gradient(180deg, var(--gold) 0%, transparent 100%);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  /* ── NAV ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(245, 230, 200, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--papyrus-dark);
    padding: 0.8rem 2rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem 2rem;
    flex-wrap: wrap;
  }
  nav a {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--smoke);
    text-decoration: none;
    transition: color 0.25s;
    padding: 0.3rem 0.5rem;
  }
  nav a:hover { color: var(--terracotta); }

  /* ── SECTIONS ── */
  section {
    padding: 5rem 2rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--terracotta-light), transparent);
    max-width: 120px;
  }

  h2 {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: 2rem;
  }

  h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--terracotta);
    margin-bottom: 0.8rem;
    margin-top: 2rem;
  }

  p { margin-bottom: 1.2rem; color: #3a2f1e; }

  /* ── TIMELINE ── */
  .timeline-section {
    background: linear-gradient(180deg, var(--papyrus) 0%, #ede0c0 50%, var(--papyrus) 100%);
    padding: 5rem 0;
  }
  .timeline-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .timeline {
    position: relative;
    margin-top: 3rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, transparent, var(--gold-light), var(--terracotta), var(--gold-light), transparent);
    transform: translateX(-50%);
  }

  .timeline-entry {
    display: flex;
    align-items: flex-start;
    margin-bottom: 3.5rem;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .timeline-entry.visible { opacity: 1; transform: translateY(0); }

  .timeline-entry:nth-child(odd) { flex-direction: row-reverse; }

  .timeline-content {
    width: calc(50% - 40px);
    background: var(--marble);
    border: 1px solid var(--marble-dark);
    border-radius: 4px;
    padding: 1.5rem;
    position: relative;
    box-shadow: 2px 4px 20px rgba(42,31,14,0.07);
  }

  .timeline-entry:nth-child(odd) .timeline-content { margin-right: 40px; }
  .timeline-entry:nth-child(even) .timeline-content { margin-left: 40px; }

  .timeline-dot {
    position: absolute;
    left: 50%;
    top: 1.2rem;
    width: 16px;
    height: 16px;
    background: var(--gold);
    border: 3px solid var(--papyrus);
    border-radius: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 2px var(--gold-light);
    z-index: 1;
  }

  .timeline-date {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }

  .timeline-content h3 { margin-top: 0; font-size: 1rem; }
  .timeline-content p { font-size: 0.9rem; margin-bottom: 0; }

  /* ── GODS GRID ── */
  .gods-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .god-card {
    background: var(--marble);
    border: 1px solid var(--marble-dark);
    border-radius: 6px;
    padding: 1.8rem 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: default;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.3s ease;
  }
  .god-card.visible { opacity: 1; transform: translateY(0); }
  .god-card:hover { box-shadow: 0 8px 30px rgba(42,31,14,0.12); transform: translateY(-3px); }

  .god-card::before {
    content: attr(data-symbol);
    position: absolute;
    top: -10px; right: 10px;
    font-size: 5rem;
    opacity: 0.07;
    line-height: 1;
    pointer-events: none;
  }

  .god-card .god-name {
    font-family: 'Cinzel Decorative', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--terracotta);
    margin-bottom: 0.2rem;
  }

  .god-card .god-domain {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
  }

  .god-card p { font-size: 0.88rem; color: #4a3a28; margin-bottom: 0; }

  /* ── QUOTE BLOCK ── */
  .quote-block {
    border-left: 4px solid var(--gold);
    padding: 1.5rem 2rem;
    margin: 3rem 0;
    background: rgba(200,146,10,0.05);
    border-radius: 0 6px 6px 0;
  }
  .quote-block blockquote {
    font-size: 1.3rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--ink);
    margin-bottom: 0.8rem;
  }
  .quote-block cite {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--smoke);
    text-transform: uppercase;
  }

  /* ── ATHENS CARD ── */
  .athens-feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2rem;
  }

  .athens-sites {
    list-style: none;
    margin-top: 1.5rem;
  }
  .athens-sites li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--papyrus-dark);
    font-size: 0.92rem;
  }
  .athens-sites li:last-child { border-bottom: none; }

  .site-num {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    color: var(--gold);
    font-weight: 600;
    min-width: 28px;
    margin-top: 2px;
  }

  .site-info strong {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    color: var(--terracotta);
    display: block;
    margin-bottom: 0.2rem;
  }

  /* ── MYTHS ── */
  .myths-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 2.5rem;
  }

  .myth-card {
    border: 1px solid var(--marble-dark);
    border-radius: 6px;
    overflow: hidden;
    background: var(--marble);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .myth-card.visible { opacity: 1; transform: translateY(0); }

  .myth-header {
    background: var(--terracotta);
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .myth-header h3 {
    color: var(--papyrus);
    font-size: 1rem;
    margin: 0;
    font-family: 'Cinzel Decorative', serif;
  }
  .myth-emoji { font-size: 1.5rem; }

  .myth-body { padding: 1.5rem; }
  .myth-body p { font-size: 0.88rem; margin-bottom: 0; }

  /* ── FUN FACTS TICKER ── */
  .ticker-wrap {
    background: var(--aegean);
    padding: 0.8rem 0;
    overflow: hidden;
    position: relative;
  }
  .ticker-wrap::before, .ticker-wrap::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 80px;
    z-index: 2;
  }
  .ticker-wrap::before { left: 0; background: linear-gradient(90deg, var(--aegean), transparent); }
  .ticker-wrap::after { right: 0; background: linear-gradient(-90deg, var(--aegean), transparent); }

  .ticker-track {
    display: flex;
    gap: 4rem;
    width: max-content;
    animation: ticker 40s linear infinite;
  }

  .ticker-item {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--papyrus);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .ticker-item::before { content: '✦'; color: var(--gold-light); font-size: 0.6rem; }

  /* ── QUIZ ── */
  .quiz-section {
    background: linear-gradient(135deg, var(--ink) 0%, #3a2f1e 100%);
    padding: 5rem 2rem;
  }
  .quiz-inner { max-width: 680px; margin: 0 auto; text-align: center; }
  .quiz-inner .section-label { justify-content: center; color: var(--gold-light); }
  .quiz-inner .section-label::after { display: none; }
  .quiz-inner h2 { color: var(--papyrus); }

  .quiz-card {
    background: rgba(245,230,200,0.06);
    border: 1px solid rgba(200,146,10,0.3);
    border-radius: 8px;
    padding: 2.5rem;
    text-align: left;
    margin-top: 2rem;
  }

  .quiz-q {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    color: var(--papyrus);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .quiz-options {
    display: grid;
    gap: 0.8rem;
  }

  .quiz-opt {
    background: rgba(245,230,200,0.05);
    border: 1px solid rgba(200,146,10,0.2);
    border-radius: 4px;
    padding: 0.9rem 1.2rem;
    color: var(--papyrus-dark);
    font-family: 'EB Garamond', serif;
    font-size: 0.95rem;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
  }
  .quiz-opt:hover { background: rgba(200,146,10,0.1); border-color: var(--gold); transform: translateX(4px); }
  .quiz-opt.correct { background: rgba(26,92,122,0.3); border-color: var(--aegean-light); color: #a8d8ea; }
  .quiz-opt.wrong { background: rgba(192,82,42,0.2); border-color: var(--terracotta-light); color: #f0a080; }
  .quiz-opt:disabled { cursor: default; transform: none; }

  .quiz-feedback {
    margin-top: 1.2rem;
    min-height: 2rem;
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--papyrus-dark);
    text-align: center;
    opacity: 0;
    transition: opacity 0.4s;
  }
  .quiz-feedback.show { opacity: 1; }

  .quiz-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
  }

  .quiz-counter {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    color: var(--smoke);
    letter-spacing: 0.2em;
  }

  .btn-next {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: var(--terracotta);
    color: var(--papyrus);
    border: none;
    padding: 0.8rem 1.8rem;
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.2s;
    opacity: 0;
    pointer-events: none;
  }
  .btn-next.show { opacity: 1; pointer-events: all; }
  .btn-next:hover { background: var(--terracotta-light); }

  .quiz-score {
    display: none;
    text-align: center;
    padding: 2rem;
  }
  .quiz-score.show { display: block; }
  .score-big {
    font-family: 'Cinzel Decorative', serif;
    font-size: 4rem;
    color: var(--gold-light);
    display: block;
    margin-bottom: 0.5rem;
  }
  .score-msg { color: var(--papyrus-dark); font-style: italic; font-size: 1.1rem; }

  /* ── FOOTER ── */
  footer {
    background: var(--ink);
    padding: 3rem 2rem;
    text-align: center;
    color: var(--smoke);
  }
  footer .footer-logo {
    font-family: 'Cinzel Decorative', serif;
    font-size: 1.4rem;
    color: var(--gold-light);
    margin-bottom: 0.8rem;
  }
  footer p { font-size: 0.85rem; margin-bottom: 0; }
  footer strong { color: var(--terracotta-light); }

  /* ── DIVIDER ── */
  .ornament {
    text-align: center;
    color: var(--gold);
    font-size: 1.2rem;
    letter-spacing: 0.5rem;
    margin: 1rem 0;
    opacity: 0.5;
  }

  /* ── HIGHLIGHTS BOX ── */
  .highlight-box {
    background: linear-gradient(135deg, rgba(26,92,122,0.08), rgba(200,146,10,0.06));
    border: 1px solid rgba(26,92,122,0.2);
    border-radius: 6px;
    padding: 1.5rem 2rem;
    margin: 2rem 0;
  }
  .highlight-box h3 { margin-top: 0; color: var(--aegean); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(1); opacity: 0.7; }
    50% { transform: scaleY(1.3); opacity: 1; }
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 680px) {
    .timeline::before { left: 24px; }
    .timeline-entry, .timeline-entry:nth-child(odd) { flex-direction: column; padding-left: 56px; }
    .timeline-content { width: 100%; }
    .timeline-entry:nth-child(odd) .timeline-content { margin-right: 0; }
    .timeline-entry:nth-child(even) .timeline-content { margin-left: 0; }
    .timeline-dot { left: 24px; }
    .athens-feature { grid-template-columns: 1fr; gap: 1.5rem; }
    .hero-columns { display: none; }
  }
</style>
</head>
<body>

<!-- HERO -->
<header class="hero">
  <div class="hero-columns">
    <div class="column" style="height:160px"></div>
    <div class="column" style="height:200px"></div>
    <div class="column" style="height:140px"></div>
    <div class="column" style="height:220px"></div>
    <div class="column" style="height:180px"></div>
    <div class="column" style="height:160px"></div>
    <div class="column" style="height:200px"></div>
    <div class="column" style="height:140px"></div>
  </div>

  <p class="hero-eyebrow">Athens, Greece</p>
  <h1>Ancient<span>Greece</span></h1>
  <p class="hero-subtitle">A Living History · A Personal Journey</p>
  <p class="hero-dedication">Made with love for <strong>Christine</strong> — welcome to the cradle of civilisation ❤️</p>

  <div class="scroll-hint">
    <span>Scroll to explore</span>
    <div class="scroll-arrow"></div>
  </div>
</header>

<!-- NAV -->
<nav>
  <a href="#intro">Overview</a>
  <a href="#timeline">Timeline</a>
  <a href="#gods">The Gods</a>
  <a href="#myths">Myths</a>
  <a href="#athens">Athens Today</a>
  <a href="#quiz">Quiz</a>
</nav>

